{
    admin localhost:2019
}

# === NEW DOMAIN: dunky.ai ===

# Base domain health check
dunky.ai {
    tls {
        dns cloudflare {env.CLOUDFLARE_API_TOKEN}
    }
    respond "ok" 200
}

# Provisioning API
api.dunky.ai {
    tls {
        dns cloudflare {env.CLOUDFLARE_API_TOKEN}
    }
    reverse_proxy localhost:3500
}

# Instance routes are added dynamically via the Caddy admin API
# Each instance gets: {id}.dunky.ai → localhost:{port}
# Wildcard TLS covers all subdomains
*.dunky.ai {
    tls {
        dns cloudflare {env.CLOUDFLARE_API_TOKEN}
    }
    respond "Instance not found" 404
}

# === OLD DOMAIN REDIRECTS ===

# Redirect old base domain
agents.theagentpost.co {
    tls {
        dns cloudflare {env.CLOUDFLARE_API_TOKEN}
    }
    redir https://dunky.ai{uri} permanent
}

# Redirect old API domain
api.agents.theagentpost.co {
    tls {
        dns cloudflare {env.CLOUDFLARE_API_TOKEN}
    }
    redir https://api.dunky.ai{uri} permanent
}

# Redirect old instance subdomains
*.agents.theagentpost.co {
    tls {
        dns cloudflare {env.CLOUDFLARE_API_TOKEN}
    }
    redir https://{labels.3}.dunky.ai{uri} permanent
}

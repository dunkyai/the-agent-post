<%- include('partials/head', { title: 'Chat' }) %>
<div class="app">
  <%- include('partials/nav', { active: 'chat' }) %>
  <div class="main full-width" style="padding: 0;">
    <div style="display: flex; height: 100%; overflow: hidden;">
      <!-- Thread Sidebar -->
      <div class="thread-sidebar" id="threadSidebar">
        <form method="POST" action="/chat/threads" style="margin: 0; padding: 8px;">
          <button type="submit" class="btn" style="width: 100%; font-size: 13px;">+ New Chat</button>
        </form>
        <div class="thread-list" id="threadList">
          <% if (typeof threads !== 'undefined' && threads.length > 0) { %>
            <% threads.forEach(function(t) { %>
              <% const tid = t.external_id.replace('chat:', ''); %>
              <a href="/chat?thread=<%= tid %>" class="thread-item <%= activeThread === tid ? 'active' : '' %>">
                <div class="thread-title"><%= t.title || t.preview?.slice(0, 40) || 'New conversation' %></div>
                <div class="thread-meta"><%= new Date(t.updated_at + 'Z').toLocaleDateString('en-US', { month: 'short', day: 'numeric' }) %></div>
                <button type="button" class="thread-delete" onclick="event.preventDefault();event.stopPropagation();if(confirm('Delete this conversation?')){fetch('/chat/threads/<%= tid %>',{method:'DELETE'}).then(function(){window.location.href='/chat'})}" title="Delete">&times;</button>
              </a>
            <% }); %>
          <% } else { %>
            <p style="color: var(--text-secondary); text-align: center; font-size: 12px; padding: 16px;">No conversations yet</p>
          <% } %>
        </div>
      </div>

      <!-- Chat Area -->
      <div class="chat-container" style="flex: 1;">
        <div style="display: flex; justify-content: space-between; align-items: center; padding: 16px 20px 12px;">
          <h2 style="margin: 0;">Chat</h2>
          <% if (activeThread) { %>
            <form method="POST" action="/chat/reset" style="margin: 0;" onsubmit="return confirm('Delete this conversation and start fresh?');">
              <input type="hidden" name="threadId" value="<%= activeThread %>">
              <button type="submit" class="btn" style="padding: 8px 16px; font-size: 13px; font-weight: 500;">Start this conversation over</button>
            </form>
          <% } %>
        </div>
      <div class="chat-messages" id="chatMessages">
        <% messages.forEach(function(msg) { %>
          <div class="chat-message <%= msg.role %>">
            <% if (msg.role === 'user') { %>
              <div class="avatar" title="<%= userName %>"><%= userName.charAt(0) %></div>
            <% } else { %>
              <div class="avatar agent-avatar" title="<%= agentName %>"><img src="/mascot.webp" alt="<%= agentName %>" /></div>
            <% } %>
            <div class="bubble"><%= msg.content %></div>
          </div>
        <% }); %>
        <% if (messages.length === 0) { %>
          <p style="color: var(--text-secondary); text-align: center; margin-top: 40px;">
            Send a message to start chatting with your agent.
          </p>
        <% } %>
      </div>
      <div class="chat-error" id="chatError"></div>
      <div id="filePreview" style="display:none; padding:6px 12px; background:var(--bg-secondary, #f5f5f5); border-radius:8px 8px 0 0; font-size:12px; color:var(--text-secondary); display:none; flex-wrap:wrap; gap:6px; align-items:center;"></div>
      <form class="chat-input-form" id="chatForm" style="position: relative;">
        <div id="shortcutDropdown" style="display:none; position:absolute; bottom:100%; left:0; right:60px; background:var(--bg, #fff); border:1px solid var(--border, #e0e0e0); border-radius:8px; box-shadow:0 -4px 16px rgba(0,0,0,0.1); max-height:200px; overflow-y:auto; z-index:100; margin-bottom:4px;"></div>
        <input type="text" id="chatInput" placeholder="Type a message... (;shortcut for quick actions)" autocomplete="off">
        <label id="fileBtn" class="btn file-btn" title="Attach files">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21.44 11.05l-9.19 9.19a6 6 0 0 1-8.49-8.49l9.19-9.19a4 4 0 0 1 5.66 5.66l-9.2 9.19a2 2 0 0 1-2.83-2.83l8.49-8.48"/></svg>
          <input type="file" id="fileInput" multiple accept="image/*,audio/*,video/*,.pdf,.txt,.csv,.md,.json" style="display:none">
        </label>
        <button type="button" id="micBtn" class="btn mic-btn" title="Record audio message">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" y1="19" x2="12" y2="23"/><line x1="8" y1="23" x2="16" y2="23"/></svg>
        </button>
        <button type="submit" class="btn" id="chatSend">Send</button>
      </form>
      <div id="usageIndicator" style="text-align: center; font-size: 11px; color: var(--text-secondary); padding: 4px 0 0;"></div>
    </div>
    </div><!-- end flex -->
  </div>
</div>
<style>
.thread-sidebar {
  width: 220px;
  min-width: 220px;
  border-right: 1px solid var(--border, #e0e0e0);
  background: var(--bg-secondary, #f9f9f9);
  display: flex;
  flex-direction: column;
  overflow: hidden;
}
.thread-list {
  flex: 1;
  overflow-y: auto;
  padding: 0 4px;
}
.thread-item {
  display: block;
  padding: 10px 12px;
  border-radius: 6px;
  text-decoration: none;
  color: var(--fg);
  font-size: 13px;
  position: relative;
  margin: 2px 0;
  transition: background 0.15s;
}
.thread-item:hover { background: var(--bg, #fff); }
.thread-item.active { background: var(--bg, #fff); font-weight: 500; }
.thread-title {
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  padding-right: 20px;
}
.thread-meta {
  font-size: 11px;
  color: var(--text-secondary);
  margin-top: 2px;
}
.thread-delete {
  position: absolute;
  top: 8px;
  right: 6px;
  background: none;
  border: none;
  color: var(--text-secondary);
  cursor: pointer;
  font-size: 16px;
  line-height: 1;
  opacity: 0;
  transition: opacity 0.15s;
  padding: 2px 4px;
}
.thread-item:hover .thread-delete { opacity: 0.6; }
.thread-delete:hover { opacity: 1 !important; color: var(--danger, #DC2626); }
</style>
<script>
  window.__chatConfig = {
    agentName: "<%= agentName %>",
    userName: "<%= userName %>",
    threadId: "<%= activeThread || '' %>"
  };
</script>
<script src="/chat.js?v=<%= Date.now() %>"></script>
<script>
(function() {
  fetch("/usage/api").then(function(r) { return r.json(); }).then(function(d) {
    var el = document.getElementById("usageIndicator");
    if (!el) return;
    var pct = d.used / d.limit;
    var color = pct >= 1 ? "#DC2626" : pct >= 0.8 ? "#D97706" : "var(--text-secondary)";
    el.style.color = color;
    el.textContent = d.used + " / " + d.limit + " messages this month";
  }).catch(function() {});
})();
</script>
<script>
(function() {
  var input = document.getElementById('chatInput');
  var dropdown = document.getElementById('shortcutDropdown');
  var shortcuts = [];
  var selectedIndex = -1;

  // Fetch shortcuts once
  fetch('/shortcuts/api').then(function(r) { return r.json(); }).then(function(d) {
    shortcuts = d.shortcuts || [];
  }).catch(function() {});

  function renderDropdown(filtered) {
    if (!filtered.length) { dropdown.style.display = 'none'; return; }
    selectedIndex = 0;
    dropdown.style.display = 'block';
    dropdown.innerHTML = filtered.map(function(s, i) {
      return '<div class="sc-item' + (i === 0 ? ' sc-selected' : '') + '" data-trigger="' + s.trigger + '" style="padding:8px 12px;cursor:pointer;border-bottom:1px solid var(--border, #eee);">'
        + '<div style="font-weight:500;font-size:13px;"><span style="color:var(--accent);">;</span>' + escapeHtml(s.trigger) + ' <span style="color:var(--text-secondary);font-weight:400;font-size:12px;">— ' + escapeHtml(s.name) + '</span></div>'
        + (s.description ? '<div style="font-size:11px;color:var(--text-secondary);margin-top:2px;">' + escapeHtml(s.description) + '</div>' : '')
        + '</div>';
    }).join('');
  }

  function escapeHtml(s) { var d = document.createElement('div'); d.textContent = s; return d.innerHTML; }

  function selectItem(trigger) {
    var val = input.value;
    var semiIdx = val.lastIndexOf(';');
    input.value = ';' + trigger + ' ';
    dropdown.style.display = 'none';
    input.focus();
  }

  function updateHighlight() {
    var items = dropdown.querySelectorAll('.sc-item');
    items.forEach(function(el, i) {
      el.classList.toggle('sc-selected', i === selectedIndex);
    });
  }

  input.addEventListener('input', function() {
    var val = this.value;
    var semiIdx = val.lastIndexOf(';');
    if (semiIdx === -1 || semiIdx !== 0) { dropdown.style.display = 'none'; return; }
    var query = val.slice(semiIdx + 1).toLowerCase().split(' ')[0];
    if (val.indexOf(' ') > semiIdx + 1) { dropdown.style.display = 'none'; return; }
    var filtered = shortcuts.filter(function(s) {
      return s.trigger.toLowerCase().indexOf(query) === 0
        || s.name.toLowerCase().indexOf(query) !== -1;
    });
    renderDropdown(filtered);
  });

  input.addEventListener('keydown', function(e) {
    if (dropdown.style.display === 'none') return;
    var items = dropdown.querySelectorAll('.sc-item');
    if (e.key === 'ArrowDown') {
      e.preventDefault();
      selectedIndex = Math.min(selectedIndex + 1, items.length - 1);
      updateHighlight();
    } else if (e.key === 'ArrowUp') {
      e.preventDefault();
      selectedIndex = Math.max(selectedIndex - 1, 0);
      updateHighlight();
    } else if (e.key === 'Tab' || e.key === 'Enter') {
      if (selectedIndex >= 0 && selectedIndex < items.length) {
        e.preventDefault();
        selectItem(items[selectedIndex].getAttribute('data-trigger'));
      }
    } else if (e.key === 'Escape') {
      dropdown.style.display = 'none';
    }
  });

  dropdown.addEventListener('click', function(e) {
    var item = e.target.closest('.sc-item');
    if (item) selectItem(item.getAttribute('data-trigger'));
  });

  document.addEventListener('click', function(e) {
    if (!dropdown.contains(e.target) && e.target !== input) {
      dropdown.style.display = 'none';
    }
  });
})();
</script>
<script>
(function() {
  var micBtn = document.getElementById('micBtn');
  var chatInput = document.getElementById('chatInput');
  var chatForm = document.getElementById('chatForm');
  var mediaRecorder = null;
  var audioChunks = [];
  var recording = false;

  if (!navigator.mediaDevices || !navigator.mediaDevices.getUserMedia) {
    micBtn.style.display = 'none';
    return;
  }

  micBtn.addEventListener('click', async function() {
    if (recording) {
      // Stop recording
      mediaRecorder.stop();
      return;
    }

    try {
      var stream = await navigator.mediaDevices.getUserMedia({ audio: true });
      audioChunks = [];
      mediaRecorder = new MediaRecorder(stream, { mimeType: 'audio/webm' });

      mediaRecorder.ondataavailable = function(e) {
        if (e.data.size > 0) audioChunks.push(e.data);
      };

      mediaRecorder.onstop = async function() {
        recording = false;
        window.__isRecording = false;
        micBtn.classList.remove('mic-recording');
        micBtn.title = 'Record audio message';
        stream.getTracks().forEach(function(t) { t.stop(); });

        if (audioChunks.length === 0) return;

        // If there's text in the input (e.g. a shortcut), attach as file and auto-submit
        var inputText = chatInput.value.trim();
        if (inputText || window.__submitAfterRecording) {
          window.__submitAfterRecording = false;
          var blob = new Blob(audioChunks, { type: 'audio/webm' });
          var file = new File([blob], 'recording.webm', { type: 'audio/webm' });
          if (window.__addFiles) window.__addFiles([file]);
          // Trigger submit now that the file is attached
          setTimeout(function() {
            var form = document.getElementById('chatForm');
            if (form) form.dispatchEvent(new Event('submit'));
          }, 50);
          return;
        }

        var blob = new Blob(audioChunks, { type: 'audio/webm' });
        var formData = new FormData();
        formData.append('audio', blob, 'recording.webm');
        if (window.__chatConfig?.threadId) formData.append('threadId', window.__chatConfig.threadId);

        chatInput.placeholder = 'Transcribing audio...';

        try {
          var res = await fetch('/chat/audio', { method: 'POST', body: formData });
          var data = await res.json();
          if (data.ok && data.transcript) {
            // Show transcribed text and trigger polling (chat.js handles it)
            chatInput.value = '';
            chatInput.placeholder = 'Type a message... (;shortcut for quick actions)';
            // Dispatch the same event chat.js listens for
            var msgEvent = new CustomEvent('audioMessageSent', { detail: { taskId: data.taskId, transcript: data.transcript } });
            document.dispatchEvent(msgEvent);
            // Add user message to chat (same as chat.js does on submit)
            if (window.addUserMessage) window.addUserMessage(data.transcript);
            if (window.startPolling) window.startPolling(data.taskId);
          } else {
            alert(data.error || 'Failed to transcribe audio');
          }
        } catch (err) {
          alert('Failed to send audio: ' + err.message);
        } finally {
          chatInput.placeholder = 'Type a message... (;shortcut for quick actions)';
        }
      };

      mediaRecorder.start();
      recording = true;
      window.__isRecording = true;
      window.__stopRecording = function() {
        if (mediaRecorder && recording) mediaRecorder.stop();
      };
      micBtn.classList.add('mic-recording');
      micBtn.title = 'Stop recording';
    } catch (err) {
      console.error('Mic error:', err);
      var chatError = document.getElementById('chatError');
      if (chatError) {
        chatError.textContent = 'Microphone access denied. Click the lock icon in the address bar → Microphone → Allow, then refresh.';
        chatError.style.color = 'var(--danger, #DC2626)';
      }
    }
  });
})();
</script>
<style>
.sc-item:hover, .sc-selected { background: var(--bg-secondary, #f5f5f5); }
.sc-item:last-child { border-bottom: none !important; }
.mic-btn {
  padding: 8px 10px;
  background: transparent;
  color: var(--text-secondary);
  border: 1px solid var(--border, #e0e0e0);
  flex-shrink: 0;
}
.mic-btn:hover { color: var(--fg); background: var(--bg-secondary, #f5f5f5); }
.mic-recording {
  color: #DC2626 !important;
  background: #FEE2E2 !important;
  border-color: #DC2626 !important;
  animation: mic-pulse 1s infinite;
}
@keyframes mic-pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.6; }
}
.file-btn {
  padding: 8px 10px;
  background: transparent;
  color: var(--text-secondary);
  border: 1px solid var(--border, #e0e0e0);
  flex-shrink: 0;
  cursor: pointer;
}
.file-btn:hover { color: var(--fg); background: var(--bg-secondary, #f5f5f5); }
.drop-overlay {
  position: absolute; inset: 0; z-index: 200;
  background: rgba(124, 58, 237, 0.08);
  border: 2px dashed var(--accent, #7C3AED);
  border-radius: 12px;
  display: flex; align-items: center; justify-content: center;
  font-size: 16px; font-weight: 600; color: var(--accent, #7C3AED);
  pointer-events: none;
}
.file-chip {
  display: inline-flex; align-items: center; gap: 4px;
  background: var(--bg, #fff); border: 1px solid var(--border, #e0e0e0);
  border-radius: 6px; padding: 2px 8px; font-size: 12px;
}
.file-chip-x { cursor: pointer; opacity: 0.5; font-size: 14px; }
.file-chip-x:hover { opacity: 1; }
</style>
<script>
(function() {
  var chatArea = document.querySelector('.chat-container');
  var chatInput = document.getElementById('chatInput');
  var chatForm = document.getElementById('chatForm');
  var fileInput = document.getElementById('fileInput');
  var filePreview = document.getElementById('filePreview');
  var pendingFiles = [];
  window.__pendingFiles = pendingFiles;
  var dropOverlay = null;

  function updatePreview() {
    if (pendingFiles.length === 0) {
      filePreview.style.display = 'none';
      filePreview.innerHTML = '';
      return;
    }
    filePreview.style.display = 'flex';
    filePreview.innerHTML = pendingFiles.map(function(f, i) {
      var size = f.size < 1024 * 1024 ? Math.round(f.size / 1024) + 'KB' : (f.size / 1024 / 1024).toFixed(1) + 'MB';
      return '<span class="file-chip">' + escapeHtml(f.name) + ' (' + size + ') <span class="file-chip-x" data-idx="' + i + '">&times;</span></span>';
    }).join('');
  }

  function escapeHtml(s) { var d = document.createElement('div'); d.textContent = s; return d.innerHTML; }

  function addFiles(fileList) {
    for (var i = 0; i < fileList.length; i++) {
      if (pendingFiles.length >= 10) break;
      pendingFiles.push(fileList[i]);
    }
    window.__pendingFiles = pendingFiles;
    updatePreview();
  }
  window.__addFiles = addFiles;

  // File button
  fileInput.addEventListener('change', function() {
    if (this.files.length) addFiles(this.files);
    this.value = '';
  });

  // Remove file chips
  filePreview.addEventListener('click', function(e) {
    var x = e.target.closest('.file-chip-x');
    if (!x) return;
    var idx = parseInt(x.getAttribute('data-idx'));
    pendingFiles.splice(idx, 1);
    updatePreview();
  });

  // Drag and drop on the entire chat area
  var dragCounter = 0;
  chatArea.addEventListener('dragenter', function(e) {
    e.preventDefault();
    dragCounter++;
    if (!dropOverlay) {
      dropOverlay = document.createElement('div');
      dropOverlay.className = 'drop-overlay';
      dropOverlay.textContent = 'Drop files here';
      chatArea.style.position = 'relative';
      chatArea.appendChild(dropOverlay);
    }
  });
  chatArea.addEventListener('dragleave', function(e) {
    e.preventDefault();
    dragCounter--;
    if (dragCounter <= 0) {
      dragCounter = 0;
      if (dropOverlay) { dropOverlay.remove(); dropOverlay = null; }
    }
  });
  chatArea.addEventListener('dragover', function(e) { e.preventDefault(); });
  chatArea.addEventListener('drop', function(e) {
    e.preventDefault();
    dragCounter = 0;
    if (dropOverlay) { dropOverlay.remove(); dropOverlay = null; }
    if (e.dataTransfer.files.length) addFiles(e.dataTransfer.files);
  });

  // File upload handler — called by chat.js when pendingFiles exist
  window.__handleFileUpload = function() {
    var text = chatInput.value.trim();

    // Show user message
    var displayMsg = text || ('Attached ' + pendingFiles.length + ' file(s)');
    if (pendingFiles.length > 0) {
      displayMsg += '\n[' + pendingFiles.map(function(f) { return f.name; }).join(', ') + ']';
    }
    if (window.addUserMessage) window.addUserMessage(displayMsg);
    chatInput.value = '';

    var formData = new FormData();
    formData.append('message', text);
    if (window.__chatConfig?.threadId) formData.append('threadId', window.__chatConfig.threadId);
    for (var i = 0; i < pendingFiles.length; i++) {
      formData.append('files', pendingFiles[i]);
    }
    pendingFiles = [];
    window.__pendingFiles = pendingFiles;
    updatePreview();

    // Show uploading indicator
    var messages = document.getElementById('chatMessages');
    var uploading = document.createElement('div');
    uploading.className = 'chat-message assistant thinking-indicator';
    uploading.id = 'uploadingIndicator';
    var agentName = window.__chatConfig?.agentName || 'Agent';
    uploading.innerHTML = '<div class="avatar agent-avatar" title="' + agentName + '"><img src="/mascot.webp" alt="' + agentName + '" /></div><div class="bubble thinking-bubble"><span class="spinner"></span> <span class="thinking-text">Uploading files...</span></div>';
    messages.appendChild(uploading);
    messages.scrollTop = messages.scrollHeight;

    fetch('/chat/upload', { method: 'POST', body: formData })
      .then(function(r) { return r.json(); })
      .then(function(data) {
        var ind = document.getElementById('uploadingIndicator');
        if (ind) ind.remove();
        if (data.ok) {
          // Show Drive upload notification if images were saved
          if (data.driveUrls && data.driveUrls.length > 0) {
            if (window.addSystemMessage) {
              window.addSystemMessage('Your ' + data.driveUrls.length + ' image(s) have been saved to Google Drive so I can reference them later in this conversation.');
            }
          }
          if (window.startPolling) window.startPolling(data.taskId);
        } else {
          document.getElementById('chatError').textContent = data.error || 'Upload failed';
        }
      })
      .catch(function(err) {
        var ind = document.getElementById('uploadingIndicator');
        if (ind) ind.remove();
        document.getElementById('chatError').textContent = err.message || 'Upload failed';
      });
  };
})();
</script>
<%- include('partials/foot') %>

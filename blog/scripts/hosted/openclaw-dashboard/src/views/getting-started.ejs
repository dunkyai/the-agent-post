<%- include('partials/head', { title: 'Getting Started' }) %>
<div class="app">
  <%- include('partials/nav', { active: 'getting-started' }) %>
  <div class="main">
    <h2>Getting Started</h2>
    <%- include('partials/flash', { flash }) %>

    <form method="POST" action="/getting-started">
      <h3 class="gs-section">Identity</h3>
      <div class="gs-row">
        <div class="form-group">
          <label for="agent_name">Agent Name</label>
          <input type="text" id="agent_name" name="agent_name" value="<%= agentName %>" placeholder="e.g. Archie, Nova, Pepper...">
        </div>
        <div class="form-group">
          <label for="user_name">Your Name</label>
          <input type="text" id="user_name" name="user_name" value="<%= userName %>" placeholder="e.g. Elizabeth, Alex...">
        </div>
      </div>

      <h3 class="gs-section">Agent Context</h3>
      <p style="font-size: 12px; color: var(--text-secondary); margin: -4px 0 10px;">The more context you provide, the better your agent performs.</p>

      <div class="form-group">
        <label for="context_company">About Your Company</label>
        <textarea id="context_company" name="context_company" rows="2" placeholder="e.g. We're a seed-stage VC fund that invests in developer tools and infrastructure."><%= contextCompany %></textarea>
      </div>
      <div class="form-group">
        <label for="context_user">About You</label>
        <textarea id="context_user" name="context_user" rows="2" placeholder="e.g. I'm a GP focused on sourcing deals in the AI/ML space."><%= contextUser %></textarea>
      </div>
      <div class="form-group">
        <label for="context_rules">Rules & Guidelines</label>
        <textarea id="context_rules" name="context_rules" rows="2" placeholder="e.g. Always be professional. Use a warm but concise tone."><%= contextRules %></textarea>
      </div>
      <div class="form-group">
        <label for="context_knowledge">Knowledge Base</label>
        <textarea id="context_knowledge" name="context_knowledge" rows="2" placeholder="e.g. Our fund size is $50M. Typical check size is $500K-$2M."><%= contextKnowledge %></textarea>
      </div>

      <button type="submit" class="btn" style="margin-bottom: 16px;">Save</button>
    </form>

    <h3 class="gs-section" style="border-top: 1px solid var(--rule-light, #e0e0e0); padding-top: 16px;">Auto-fill from LinkedIn</h3>
    <div class="form-group">
      <div style="display: flex; gap: 8px; align-items: center;">
        <input type="url" id="linkedin_url" placeholder="https://linkedin.com/in/yourname" style="flex: 1;">
        <button type="button" id="research-btn" class="btn btn-sm" style="white-space: nowrap;">Research me</button>
      </div>
    </div>
    <div id="research-status" style="display: none; font-size: 13px; color: var(--text-secondary);"></div>
  </div>
</div>
<style>
  .gs-section { font-size: 11px; text-transform: uppercase; font-weight: 600; color: var(--text-secondary); letter-spacing: 0.5px; margin: 0 0 8px; }
  .gs-row { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
  .getting-started .form-group { margin-bottom: 10px; }
  .getting-started textarea, .getting-started input[type="text"], .getting-started input[type="url"] { font-size: 13px; }
</style>
<script>
(function () {
  document.querySelector('.main').classList.add('getting-started');
  var researchBtn = document.getElementById("research-btn");
  var statusDiv = document.getElementById("research-status");

  if (!researchBtn) return;

  researchBtn.addEventListener("click", function () {
    var url = document.getElementById("linkedin_url").value.trim();
    if (!url) { alert("Enter a LinkedIn URL first."); return; }

    researchBtn.disabled = true;
    researchBtn.textContent = "Researching...";
    statusDiv.style.display = "block";
    statusDiv.style.color = "var(--text-secondary)";
    statusDiv.textContent = "Researching your LinkedIn profile and generating context...";

    fetch("/getting-started/research", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ linkedin_url: url })
    })
    .then(function (res) { return res.json(); })
    .then(function (data) {
      researchBtn.disabled = false;
      researchBtn.textContent = "Research me";
      if (data.error) {
        statusDiv.style.color = "var(--danger)";
        statusDiv.textContent = "Error: " + data.error;
        return;
      }
      // Fill the context fields with generated values
      if (data.context_company) document.getElementById("context_company").value = data.context_company;
      if (data.context_user) document.getElementById("context_user").value = data.context_user;
      if (data.context_rules) document.getElementById("context_rules").value = data.context_rules;

      statusDiv.style.color = "var(--success)";
      statusDiv.textContent = "Context generated and saved! Review the fields above and adjust as needed.";
    })
    .catch(function () {
      researchBtn.disabled = false;
      researchBtn.textContent = "Research me";
      statusDiv.style.color = "var(--danger)";
      statusDiv.textContent = "Research failed. Check your API key in Settings and try again.";
    });
  });
})();
</script>
<%- include('partials/foot') %>

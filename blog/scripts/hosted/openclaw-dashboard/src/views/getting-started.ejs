<%- include('partials/head', { title: 'Getting Started' }) %>
<div class="app">
  <%- include('partials/nav', { active: 'getting-started' }) %>
  <div class="main getting-started">
    <h2>Getting Started</h2>
    <%- include('partials/flash', { flash }) %>

    <% if (contextFilled < contextTotal) { %>
    <div class="gs-chat-nudge">
      <div class="gs-nudge-text">
        <strong>Tip:</strong> Head to <a href="/chat">Chat</a> and your agent will ask you questions to auto-fill these fields.
      </div>
      <div class="gs-progress">
        <div class="gs-progress-bar" style="width: <%= (contextFilled / contextTotal * 100) %>%;"></div>
      </div>
      <div class="gs-progress-label"><%= contextFilled %>/<%= contextTotal %> context fields filled</div>
    </div>
    <% } %>

    <form method="POST" action="/getting-started">
      <h3 class="gs-section">Identity</h3>
      <div class="gs-row">
        <div class="form-group">
          <label for="agent_name">Agent Name</label>
          <input type="text" id="agent_name" name="agent_name" value="<%= agentName %>" placeholder="e.g. Archie, Nova, Pepper...">
        </div>
        <div class="form-group">
          <label for="user_name">Your Name</label>
          <input type="text" id="user_name" name="user_name" value="<%= userName %>" placeholder="e.g. Elizabeth, Alex...">
        </div>
      </div>

      <h3 class="gs-section">Auto-fill from LinkedIn</h3>
      <div style="display: flex; gap: 8px; align-items: center; margin-bottom: 12px;">
        <input type="url" id="linkedin_url" name="linkedin_url" value="<%= linkedinUrl %>" placeholder="https://linkedin.com/in/yourname" style="flex: 1; font-size: 13px;">
        <button type="button" id="research-btn" class="btn btn-sm" style="white-space: nowrap;">Research me</button>
      </div>
      <div id="research-status" style="display: none; font-size: 12px; color: var(--text-secondary); margin-bottom: 8px;"></div>

      <h3 class="gs-section">Agent Context</h3>
      <div class="form-group">
        <label for="context_company">Company</label>
        <textarea id="context_company" name="context_company" rows="2" placeholder="What does your company do?"><%= contextCompany %></textarea>
      </div>
      <div class="form-group">
        <label for="context_user">About You</label>
        <textarea id="context_user" name="context_user" rows="2" placeholder="Your role and responsibilities"><%= contextUser %></textarea>
      </div>
      <div class="gs-row">
        <div class="form-group">
          <label for="context_rules">Rules</label>
          <textarea id="context_rules" name="context_rules" rows="2" placeholder="Tone, guidelines"><%= contextRules %></textarea>
        </div>
        <div class="form-group">
          <label for="context_knowledge">Knowledge</label>
          <textarea id="context_knowledge" name="context_knowledge" rows="2" placeholder="Key facts, numbers"><%= contextKnowledge %></textarea>
        </div>
      </div>

      <button type="submit" class="btn" style="margin-top: 4px;">Save</button>
    </form>
  </div>
</div>
<style>
  .gs-section { font-size: 11px; text-transform: uppercase; font-weight: 600; color: var(--text-secondary); letter-spacing: 0.5px; margin: 0 0 8px; }
  .gs-row { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
  .getting-started .form-group { margin-bottom: 8px; }
  .getting-started textarea, .getting-started input[type="text"], .getting-started input[type="url"] { font-size: 13px; }
  .getting-started textarea { max-height: 80px; overflow-y: auto; resize: vertical; }
  .getting-started label { font-size: 12px; }
  .gs-chat-nudge { background: var(--bg-secondary, #f5f5f5); border-radius: 8px; padding: 10px 14px; margin-bottom: 14px; }
  .gs-nudge-text { font-size: 13px; margin-bottom: 8px; }
  .gs-nudge-text a { color: var(--accent); font-weight: 500; }
  .gs-progress { height: 4px; background: var(--border, #e0e0e0); border-radius: 2px; overflow: hidden; }
  .gs-progress-bar { height: 100%; background: var(--accent, #4f46e5); border-radius: 2px; transition: width 0.3s; }
  .gs-progress-label { font-size: 11px; color: var(--text-secondary); margin-top: 4px; }
</style>
<script>
(function () {
  var researchBtn = document.getElementById("research-btn");
  var statusDiv = document.getElementById("research-status");

  if (!researchBtn) return;

  researchBtn.addEventListener("click", function () {
    var url = document.getElementById("linkedin_url").value.trim();
    if (!url) { alert("Enter a LinkedIn URL first."); return; }

    researchBtn.disabled = true;
    researchBtn.textContent = "Researching...";
    statusDiv.style.display = "block";
    statusDiv.style.color = "var(--text-secondary)";
    statusDiv.textContent = "Researching your LinkedIn profile...";

    fetch("/getting-started/research", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ linkedin_url: url })
    })
    .then(function (res) { return res.json(); })
    .then(function (data) {
      researchBtn.disabled = false;
      researchBtn.textContent = "Research me";
      if (data.error) {
        statusDiv.style.color = "var(--danger)";
        statusDiv.textContent = "Error: " + data.error;
        return;
      }
      if (data.context_company) document.getElementById("context_company").value = data.context_company;
      if (data.context_user) document.getElementById("context_user").value = data.context_user;
      if (data.context_rules) document.getElementById("context_rules").value = data.context_rules;

      statusDiv.style.color = "var(--success)";
      statusDiv.textContent = "Done! Review the fields above and hit Save.";
    })
    .catch(function () {
      researchBtn.disabled = false;
      researchBtn.textContent = "Research me";
      statusDiv.style.color = "var(--danger)";
      statusDiv.textContent = "Research failed. Check your API key in Settings.";
    });
  });
})();
</script>
<%- include('partials/foot') %>

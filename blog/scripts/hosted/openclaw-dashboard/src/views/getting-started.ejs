<%- include('partials/head', { title: 'Getting Started' }) %>
<div class="app">
  <%- include('partials/nav', { active: 'getting-started' }) %>
  <div class="main getting-started">
    <div class="gs-header">
      <h2>Getting Started</h2>
      <p class="gs-subtitle">Set up your agent's identity and context so it can work on your behalf.</p>
    </div>
    <%- include('partials/flash', { flash }) %>

    <% if (contextFilled < contextTotal) { %>
    <div class="gs-chat-nudge">
      <div class="gs-nudge-icon">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
      </div>
      <div class="gs-nudge-content">
        <div class="gs-nudge-text">
          <strong>Skip the forms.</strong> Head to <a href="/chat">Chat</a> and your agent will learn about you through conversation.
        </div>
        <div class="gs-progress">
          <div class="gs-progress-bar" style="width: <%= (contextFilled / contextTotal * 100) %>%;"></div>
        </div>
        <div class="gs-progress-label"><%= contextFilled %> of <%= contextTotal %> fields completed</div>
      </div>
    </div>
    <% } %>

    <form method="POST" action="/getting-started">
      <div class="gs-card">
        <div class="gs-card-header">
          <h3>Identity</h3>
          <p>Basic information about you and your agent.</p>
        </div>
        <div class="gs-card-body">
          <div class="gs-row">
            <div class="form-group">
              <label for="agent_name">Agent Name</label>
              <input type="text" id="agent_name" name="agent_name" value="<%= agentName %>" placeholder="e.g. Archie, Nova, Pepper...">
            </div>
            <div class="form-group">
              <label for="user_name">Your Name</label>
              <input type="text" id="user_name" name="user_name" value="<%= userName %>" placeholder="e.g. Elizabeth, Alex...">
            </div>
          </div>
          <div class="form-group">
            <label for="user_email">Your Email</label>
            <input type="email" id="user_email" name="user_email" value="<%= userEmail %>" placeholder="e.g. you@example.com">
            <span class="hint">Used for notifications when your agent needs clarification on an email</span>
          </div>
        </div>
      </div>

      <div class="gs-card">
        <div class="gs-card-header">
          <h3>LinkedIn Auto-fill</h3>
          <p>Paste your LinkedIn URL and we'll fill in the context fields for you.</p>
        </div>
        <div class="gs-card-body">
          <div class="gs-linkedin-row">
            <input type="url" id="linkedin_url" name="linkedin_url" value="<%= linkedinUrl %>" placeholder="https://linkedin.com/in/yourname">
            <button type="button" id="research-btn" class="btn btn-sm">Research me</button>
          </div>
          <div id="research-status" class="gs-research-status"></div>
        </div>
      </div>

      <div class="gs-card">
        <div class="gs-card-header">
          <h3>Agent Context</h3>
          <p>Give your agent the context it needs to represent you well.</p>
        </div>
        <div class="gs-card-body">
          <div class="form-group">
            <label for="context_company">Company</label>
            <textarea id="context_company" name="context_company" rows="3" placeholder="What does your company do? What products or services do you offer?"><%= contextCompany %></textarea>
          </div>
          <div class="form-group">
            <label for="context_user">About You</label>
            <textarea id="context_user" name="context_user" rows="3" placeholder="Your role, responsibilities, and what you'd like your agent to help with"><%= contextUser %></textarea>
          </div>
          <div class="gs-row">
            <div class="form-group">
              <label for="context_rules">Rules</label>
              <textarea id="context_rules" name="context_rules" rows="3" placeholder="Communication style, tone preferences, things to avoid"><%= contextRules %></textarea>
            </div>
            <div class="form-group">
              <label for="context_knowledge">Knowledge</label>
              <textarea id="context_knowledge" name="context_knowledge" rows="3" placeholder="Key facts, numbers, terminology your agent should know"><%= contextKnowledge %></textarea>
            </div>
          </div>
        </div>
      </div>

      <div class="gs-actions">
        <button type="submit" class="btn">Save Changes</button>
      </div>
    </form>
  </div>
</div>
<style>
  .getting-started { max-width: 720px; }
  .gs-header { margin-bottom: 24px; }
  .gs-header h2 { margin-bottom: 4px; }
  .gs-subtitle { color: var(--text-secondary); font-size: 14px; margin: 0; }

  .gs-card {
    background: #fff;
    border: 1px solid var(--rule-light);
    border-radius: 12px;
    margin-bottom: 20px;
    overflow: hidden;
  }
  .gs-card-header {
    padding: 20px 24px 0;
  }
  .gs-card-header h3 {
    font-size: 16px;
    font-weight: 600;
    margin: 0 0 4px;
    color: var(--fg);
  }
  .gs-card-header p {
    font-size: 13px;
    color: var(--text-secondary);
    margin: 0;
  }
  .gs-card-body {
    padding: 16px 24px 20px;
  }

  .gs-row { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }

  .getting-started .form-group { margin-bottom: 14px; }
  .getting-started .form-group:last-child { margin-bottom: 0; }

  .getting-started input[type="text"],
  .getting-started input[type="email"],
  .getting-started input[type="url"],
  .getting-started textarea {
    border-radius: 10px;
    font-size: 14px;
    padding: 10px 14px;
    background: var(--bg);
    width: 100%;
    box-sizing: border-box;
  }
  .getting-started textarea {
    min-height: 72px;
    max-height: 160px;
    resize: vertical;
  }

  .gs-linkedin-row {
    display: flex;
    gap: 10px;
    align-items: center;
  }
  .gs-linkedin-row input { flex: 1; }
  .gs-linkedin-row .btn { white-space: nowrap; flex-shrink: 0; }

  .gs-research-status {
    display: none;
    font-size: 13px;
    color: var(--text-secondary);
    margin-top: 10px;
    padding: 8px 12px;
    background: var(--bg);
    border-radius: 8px;
  }

  .gs-actions {
    display: flex;
    justify-content: flex-end;
    padding: 4px 0 0;
  }

  .gs-chat-nudge {
    display: flex;
    gap: 14px;
    align-items: flex-start;
    background: var(--tag-bg);
    border: 1px solid #E9D5FF;
    border-radius: 12px;
    padding: 16px 20px;
    margin-bottom: 24px;
  }
  .gs-nudge-icon {
    color: var(--accent);
    flex-shrink: 0;
    margin-top: 1px;
  }
  .gs-nudge-content { flex: 1; min-width: 0; }
  .gs-nudge-text { font-size: 14px; margin-bottom: 10px; line-height: 1.5; }
  .gs-nudge-text a { color: var(--accent); font-weight: 600; text-decoration: none; }
  .gs-nudge-text a:hover { text-decoration: underline; }
  .gs-progress { height: 6px; background: #E9D5FF; border-radius: 3px; overflow: hidden; }
  .gs-progress-bar { height: 100%; background: var(--accent); border-radius: 3px; transition: width 0.3s ease; }
  .gs-progress-label { font-size: 12px; color: var(--text-secondary); margin-top: 6px; }

  @media (max-width: 600px) {
    .gs-row { grid-template-columns: 1fr; }
    .gs-linkedin-row { flex-direction: column; }
    .gs-linkedin-row .btn { width: 100%; }
    .gs-card-header, .gs-card-body { padding-left: 16px; padding-right: 16px; }
  }
</style>
<script>
(function () {
  var researchBtn = document.getElementById("research-btn");
  var statusDiv = document.getElementById("research-status");

  if (!researchBtn) return;

  researchBtn.addEventListener("click", function () {
    var url = document.getElementById("linkedin_url").value.trim();
    if (!url) { alert("Enter a LinkedIn URL first."); return; }

    researchBtn.disabled = true;
    researchBtn.textContent = "Researching...";
    statusDiv.style.display = "block";
    statusDiv.style.color = "var(--text-secondary)";
    statusDiv.style.background = "var(--bg)";
    statusDiv.textContent = "Researching your LinkedIn profile...";

    fetch("/getting-started/research", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ linkedin_url: url })
    })
    .then(function (res) { return res.json(); })
    .then(function (data) {
      researchBtn.disabled = false;
      researchBtn.textContent = "Research me";
      if (data.error) {
        statusDiv.style.color = "var(--danger)";
        statusDiv.textContent = "Error: " + data.error;
        return;
      }
      if (data.context_company) document.getElementById("context_company").value = data.context_company;
      if (data.context_user) document.getElementById("context_user").value = data.context_user;
      if (data.context_rules) document.getElementById("context_rules").value = data.context_rules;

      statusDiv.style.color = "var(--success)";
      statusDiv.textContent = "Done! Review the fields above and hit Save.";
    })
    .catch(function () {
      researchBtn.disabled = false;
      researchBtn.textContent = "Research me";
      statusDiv.style.color = "var(--danger)";
      statusDiv.textContent = "Research failed. Check your API key in Settings.";
    });
  });
})();
</script>
<%- include('partials/foot') %>

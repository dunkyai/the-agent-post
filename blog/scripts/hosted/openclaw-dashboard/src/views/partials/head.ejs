<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' ? title + ' — OpenClaw' : 'OpenClaw' %></title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg: #FAF7F2;
      --fg: #1A1A2E;
      --accent: #6B21A8;
      --accent-light: #7C3AED;
      --text-secondary: #4A4A5A;
      --rule-light: #E5E0D8;
      --tag-bg: #F3E8FF;
      --sidebar-bg: #1A1A2E;
      --sidebar-fg: #EDEDED;
      --danger: #DC2626;
      --success: #16A34A;
    }

    body {
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
      background: var(--bg);
      color: var(--fg);
      line-height: 1.5;
      min-height: 100vh;
    }

    .app { display: flex; min-height: 100vh; }

    .sidebar {
      width: 220px;
      background: var(--sidebar-bg);
      color: var(--sidebar-fg);
      display: flex;
      flex-direction: column;
      flex-shrink: 0;
    }

    .sidebar-brand {
      padding: 24px 20px;
      border-bottom: 1px solid rgba(255,255,255,0.1);
    }

    .sidebar-brand h1 {
      font-size: 20px;
      font-weight: 700;
      letter-spacing: -0.5px;
    }

    .sidebar-nav {
      list-style: none;
      padding: 12px 0;
      flex: 1;
    }

    .sidebar-nav a {
      display: block;
      padding: 10px 20px;
      color: rgba(255,255,255,0.7);
      text-decoration: none;
      font-size: 14px;
      transition: background 0.15s, color 0.15s;
    }

    .sidebar-nav a:hover { background: rgba(255,255,255,0.08); color: #fff; }
    .sidebar-nav a.active { background: var(--accent); color: #fff; }

    .sidebar-footer { padding: 16px 20px; border-top: 1px solid rgba(255,255,255,0.1); }

    .btn-logout {
      background: none;
      border: 1px solid rgba(255,255,255,0.3);
      color: rgba(255,255,255,0.7);
      padding: 6px 16px;
      border-radius: 6px;
      cursor: pointer;
      font-size: 13px;
      width: 100%;
      transition: background 0.15s, color 0.15s;
    }
    .btn-logout:hover { background: rgba(255,255,255,0.1); color: #fff; }

    .main {
      flex: 1;
      padding: 32px 40px;
      max-width: 800px;
    }

    .main.full-width { max-width: 100%; }

    h2 {
      font-size: 24px;
      font-weight: 600;
      margin-bottom: 24px;
      color: var(--fg);
    }

    .flash {
      background: var(--tag-bg);
      color: var(--accent);
      padding: 10px 16px;
      border-radius: 8px;
      margin-bottom: 20px;
      font-size: 14px;
      border: 1px solid rgba(107, 33, 168, 0.2);
    }

    .card {
      background: #fff;
      border: 1px solid var(--rule-light);
      border-radius: 12px;
      padding: 24px;
      margin-bottom: 20px;
    }

    .card.card-compact {
      padding: 12px 16px;
      margin-bottom: 8px;
    }

    .card h3 {
      font-size: 16px;
      font-weight: 600;
      margin-bottom: 16px;
      color: var(--fg);
    }

    .card-compact h3 {
      margin-bottom: 8px;
    }

    .form-group {
      margin-bottom: 16px;
    }

    .card-compact .form-group {
      margin-bottom: 8px;
    }

    .form-group label {
      display: block;
      font-size: 13px;
      font-weight: 500;
      color: var(--text-secondary);
      margin-bottom: 6px;
    }

    .form-group input[type="text"],
    .form-group input[type="url"],
    .form-group input[type="email"],
    .form-group input[type="password"],
    .form-group input[type="number"],
    .form-group textarea,
    .form-group select {
      width: 100%;
      padding: 8px 12px;
      border: 1px solid var(--rule-light);
      border-radius: 8px;
      font-size: 14px;
      font-family: inherit;
      background: var(--bg);
      color: var(--fg);
      transition: border-color 0.15s;
    }

    .form-group input:focus,
    .form-group textarea:focus,
    .form-group select:focus {
      outline: none;
      border-color: var(--accent);
    }

    .form-group textarea { resize: vertical; min-height: 120px; }

    .form-group .hint {
      font-size: 12px;
      color: var(--text-secondary);
      margin-top: 4px;
    }

    .btn {
      display: inline-block;
      padding: 8px 20px;
      background: var(--accent);
      color: #fff;
      border: none;
      border-radius: 8px;
      font-size: 14px;
      font-weight: 500;
      cursor: pointer;
      transition: background 0.15s;
    }
    .btn:hover { background: var(--accent-light); }

    .btn.btn-sm {
      padding: 6px 16px;
      font-size: 13px;
    }

    .btn-secondary {
      background: transparent;
      color: var(--text-secondary);
      border: 1px solid var(--rule-light);
    }
    .btn-secondary:hover { background: #F0ECE6; color: var(--fg); }

    .btn-danger {
      background: var(--danger);
    }
    .btn-danger:hover { background: #EF4444; }

    .btn-outline {
      background: none;
      border: 1px solid var(--rule-light);
      color: var(--fg);
    }
    .btn-outline:hover { background: var(--bg); }

    .status-badge {
      display: inline-block;
      padding: 2px 10px;
      border-radius: 999px;
      font-size: 12px;
      font-weight: 500;
    }

    .status-connected { background: #DCFCE7; color: var(--success); }
    .status-disconnected { background: #F3F4F6; color: var(--text-secondary); }
    .status-error { background: #FEE2E2; color: var(--danger); }

    .integration-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 0;
      flex: 1;
    }

    .integration-header h3 { margin-bottom: 0; }

    .card-collapsible {
      padding: 0;
    }

    .integration-toggle {
      display: flex;
      align-items: center;
      padding: 16px 20px;
      cursor: pointer;
      list-style: none;
      user-select: none;
    }

    .integration-toggle::-webkit-details-marker { display: none; }

    .toggle-arrow {
      margin-left: 12px;
      flex-shrink: 0;
      width: 20px;
      height: 20px;
      display: flex;
      align-items: center;
      justify-content: center;
      color: var(--text-secondary);
      transition: transform 0.15s;
    }

    .toggle-arrow::after {
      content: "";
      border: solid var(--text-secondary);
      border-width: 0 2px 2px 0;
      display: inline-block;
      padding: 3px;
      transform: rotate(-45deg);
      transition: transform 0.15s;
    }

    details[open] .toggle-arrow::after {
      transform: rotate(45deg);
    }

    .integration-body {
      padding: 0 20px 16px;
    }

    .login-page {
      display: flex;
      align-items: center;
      justify-content: center;
      min-height: 100vh;
      background: var(--bg);
    }

    .login-card {
      background: #fff;
      border: 1px solid var(--rule-light);
      border-radius: 16px;
      padding: 40px;
      width: 100%;
      max-width: 400px;
    }

    .login-card h1 {
      font-size: 28px;
      font-weight: 700;
      margin-bottom: 8px;
      text-align: center;
    }

    .login-card p {
      text-align: center;
      color: var(--text-secondary);
      font-size: 14px;
      margin-bottom: 24px;
    }

    .login-error {
      background: #FEE2E2;
      color: var(--danger);
      padding: 10px 16px;
      border-radius: 8px;
      margin-bottom: 16px;
      font-size: 14px;
    }

    .login-success {
      background: #F3E8FF;
      padding: 28px 24px;
      border-radius: 12px;
      text-align: center;
    }

    .chat-container {
      display: flex;
      flex-direction: column;
      height: calc(100vh - 64px);
    }

    .chat-messages {
      flex: 1;
      overflow-y: auto;
      padding: 16px 0;
    }

    .chat-message {
      margin-bottom: 16px;
      display: flex;
      gap: 12px;
    }

    .chat-message .avatar {
      width: 32px;
      height: 32px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 14px;
      font-weight: 600;
      flex-shrink: 0;
    }

    .chat-message.user .avatar { background: var(--accent); color: #fff; }
    .chat-message.assistant .avatar { background: var(--tag-bg); color: var(--accent); }
    .chat-message .avatar.agent-avatar { background: transparent; padding: 0; overflow: hidden; }
    .chat-message .avatar.agent-avatar img { width: 100%; height: 100%; object-fit: cover; border-radius: 50%; }

    .chat-message .bubble {
      background: #fff;
      border: 1px solid var(--rule-light);
      border-radius: 12px;
      padding: 12px 16px;
      font-size: 14px;
      line-height: 1.6;
      max-width: 600px;
      word-wrap: break-word;
    }

    .bubble img { max-width: 100%; border-radius: 8px; margin: 8px 0; display: block; }
    .bubble pre { background: var(--bg); padding: 12px; border-radius: 6px; overflow-x: auto; font-size: 13px; margin: 8px 0; white-space: pre-wrap; }
    .bubble code { background: var(--bg); padding: 2px 6px; border-radius: 4px; font-size: 13px; }
    .bubble pre code { background: none; padding: 0; }
    .bubble ul, .bubble ol { margin: 8px 0; padding-left: 20px; }
    .bubble li { margin: 2px 0; }
    .bubble a { color: var(--accent); text-decoration: underline; }
    .bubble p { margin: 4px 0; }
    .bubble p:first-child { margin-top: 0; }
    .bubble p:last-child { margin-bottom: 0; }
    .chat-message.user .bubble a { color: #fff; }

    .chat-message.user .bubble {
      background: var(--accent);
      color: #fff;
      border-color: var(--accent);
    }

    .chat-input-form {
      display: flex;
      gap: 8px;
      padding: 16px 0;
      border-top: 1px solid var(--rule-light);
    }

    .chat-input-form input {
      flex: 1;
      padding: 10px 16px;
      border: 1px solid var(--rule-light);
      border-radius: 8px;
      font-size: 14px;
      font-family: inherit;
      background: #fff;
    }
    .chat-input-form input:focus { outline: none; border-color: var(--accent); }

    .thinking-bubble {
      display: flex;
      flex-direction: column;
      gap: 8px;
      color: var(--text-secondary);
      min-width: 240px;
      animation: thinking-fade-in 0.3s ease;
    }
    @keyframes thinking-fade-in {
      from { opacity: 0; transform: translateY(8px); }
      to { opacity: 1; transform: translateY(0); }
    }
    .thinking-top {
      display: flex;
      align-items: center;
      gap: 8px;
    }
    .thinking-text {
      transition: opacity 0.3s ease;
      font-size: 13px;
      font-weight: 500;
    }
    .thinking-text.fade-out { opacity: 0; }
    .thinking-dots {
      display: inline-flex;
      gap: 3px;
      margin-left: 2px;
    }
    .thinking-dots span {
      width: 5px;
      height: 5px;
      border-radius: 50%;
      background: var(--accent);
      animation: dot-bounce 1.4s ease-in-out infinite;
    }
    .thinking-dots span:nth-child(2) { animation-delay: 0.2s; }
    .thinking-dots span:nth-child(3) { animation-delay: 0.4s; }
    @keyframes dot-bounce {
      0%, 80%, 100% { opacity: 0.3; transform: scale(0.8); }
      40% { opacity: 1; transform: scale(1.2); }
    }
    .thinking-skeleton {
      display: flex;
      flex-direction: column;
      gap: 6px;
      margin-top: 4px;
    }
    .thinking-skeleton-line {
      height: 10px;
      border-radius: 4px;
      background: linear-gradient(90deg, var(--rule-light) 25%, var(--bg-secondary, #e8e8e8) 50%, var(--rule-light) 75%);
      background-size: 200% 100%;
      animation: skeleton-shimmer 1.5s ease-in-out infinite;
    }
    .thinking-skeleton-line:nth-child(1) { width: 85%; }
    .thinking-skeleton-line:nth-child(2) { width: 70%; }
    .thinking-skeleton-line:nth-child(3) { width: 55%; }
    @keyframes skeleton-shimmer {
      0% { background-position: 200% 0; }
      100% { background-position: -200% 0; }
    }
    .thinking-progress {
      height: 3px;
      border-radius: 2px;
      background: var(--rule-light);
      overflow: hidden;
    }
    .thinking-progress-bar {
      height: 100%;
      border-radius: 2px;
      background: linear-gradient(90deg, var(--accent), #8B5CF6, var(--accent));
      background-size: 200% 100%;
      animation: progress-sweep 2s ease-in-out infinite;
      width: 100%;
    }
    @keyframes progress-sweep {
      0% { background-position: 200% 0; }
      100% { background-position: -200% 0; }
    }
    .spinner { display: none; }

    /* Typewriter effect for new messages */
    .typewriter-cursor {
      display: inline-block;
      width: 2px;
      height: 1em;
      background: var(--accent);
      margin-left: 2px;
      animation: cursor-blink 0.8s step-end infinite;
      vertical-align: text-bottom;
    }
    @keyframes cursor-blink {
      0%, 100% { opacity: 1; }
      50% { opacity: 0; }
    }
    .message-appear {
      animation: msg-slide-in 0.3s ease;
    }
    @keyframes msg-slide-in {
      from { opacity: 0; transform: translateY(12px); }
      to { opacity: 1; transform: translateY(0); }
    }

    .chat-error {
      color: var(--danger);
      font-size: 13px;
      padding: 8px 0;
    }

    /* Integration grid */
    .integration-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 16px;
    }

    .integration-tile {
      background: #fff;
      border: 1px solid var(--rule-light);
      border-radius: 12px;
      overflow: hidden;
      transition: border-color 0.15s;
    }

    .integration-tile[open] {
      border-color: var(--accent);
    }

    .integration-tile.tile-disabled {
      opacity: 0.5;
      pointer-events: none;
    }

    .integration-tile-summary {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 16px;
      cursor: pointer;
      list-style: none;
    }

    .integration-tile-summary::-webkit-details-marker { display: none; }

    .integration-icon {
      width: 40px;
      height: 40px;
      border-radius: 10px;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
      overflow: hidden;
    }

    .integration-tile-info {
      flex: 1;
      min-width: 0;
    }

    .integration-tile-info h3 {
      font-size: 15px;
      font-weight: 600;
      margin: 0 0 2px;
    }

    .integration-tile-info p {
      font-size: 12px;
      color: var(--text-secondary);
      margin: 0;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .integration-tile-body {
      padding: 0 16px 16px;
      border-top: 1px solid var(--rule-light);
    }

    @media (max-width: 768px) {
      .app { flex-direction: column; }
      .sidebar { width: 100%; flex-direction: row; align-items: center; }
      .sidebar-brand { padding: 12px 16px; border-bottom: none; }
      .sidebar-brand h1 { font-size: 16px; }
      .sidebar-nav { display: flex; padding: 0; }
      .sidebar-nav a { padding: 12px 14px; font-size: 13px; }
      .sidebar-footer { padding: 8px 16px; border-top: none; }
      .btn-logout { padding: 4px 12px; }
      .main { padding: 20px 16px; }
      .integration-grid { grid-template-columns: 1fr; }
    }

    /* Tool call visibility in chat */
    .tool-calls-section {
      margin-top: 8px;
      padding-top: 8px;
      border-top: 1px solid var(--rule-light, #e0e0e0);
      font-size: 12px;
    }
    .tool-calls-section summary {
      cursor: pointer;
      color: var(--text-secondary);
      font-size: 12px;
      list-style: none;
    }
    .tool-calls-section summary:hover { color: var(--fg); }
    .tool-calls-list { padding: 4px 0; }
    .tool-call-item {
      display: flex;
      gap: 8px;
      align-items: center;
      padding: 2px 0;
      font-family: monospace;
      font-size: 11px;
    }
    .tool-name { font-weight: 600; color: var(--fg); }
    .tool-duration { color: var(--text-secondary); }
    .tool-ok { color: #16A34A; }
    .tool-error { color: #DC2626; }
  </style>
</head>
<body>

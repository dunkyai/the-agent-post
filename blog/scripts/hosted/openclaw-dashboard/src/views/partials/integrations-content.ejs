      <!-- Buffer -->
      <details class="integration-tile">
        <summary class="integration-tile-summary">
          <span class="integration-icon" style="background: #168AFF;"><img src="/logos/buffer.svg" alt="Buffer" width="24" height="24"></span>
          <div class="integration-tile-info">
            <h3>Buffer</h3>
            <p>Schedule social media posts</p>
          </div>
          <span class="status-badge status-<%= buffer.status === 'pending' ? 'disconnected' : buffer.status %>"><%= buffer.status === 'pending' ? 'choose org' : buffer.status %></span>
        </summary>
        <div class="integration-tile-body">
          <% if (buffer.error_message) { %>
            <p style="color: var(--danger); font-size: 13px; margin-bottom: 12px;"><%= buffer.error_message %></p>
          <% } %>

          <% if (buffer.status === 'pending' && buffer.pending_orgs.length > 0) { %>
            <p style="font-size: 14px; margin-bottom: 12px;">Your Buffer account has multiple organizations. Choose which one to connect:</p>
            <form method="POST" action="/integrations/buffer/select-org">
              <div style="display: flex; flex-direction: column; gap: 8px; margin-bottom: 12px;">
                <% buffer.pending_orgs.forEach(function(org, i) { %>
                  <label style="display: flex; align-items: center; gap: 8px; font-size: 14px; cursor: pointer; padding: 8px 12px; border: 1px solid var(--rule-light); border-radius: 6px;">
                    <input type="radio" name="organization_id" value="<%= org.id %>" <%= i === 0 ? '' : '' %> required>
                    <span><%= org.name %></span>
                  </label>
                <% }); %>
              </div>
              <div style="display: flex; gap: 8px;">
                <button type="submit" class="btn">Connect</button>
              </div>
            </form>
            <form method="POST" action="/integrations/buffer/disconnect" style="margin-top: 8px;">
              <button type="submit" class="btn btn-danger btn-sm">Cancel</button>
            </form>

          <% } else if (buffer.status === 'connected') { %>
            <div style="margin-bottom: 12px;">
              <label style="font-size: 13px; color: var(--text-secondary);">Connected Organization</label>
              <div style="margin-top: 4px;">
                <code style="font-size: 14px; padding: 6px 10px; background: var(--bg); border: 1px solid var(--rule-light); border-radius: 4px;"><%= buffer.organization_name || 'Connected' %></code>
              </div>
            </div>

            <% if (buffer.channels_error) { %>
              <p style="color: var(--text-secondary); font-size: 13px; margin-bottom: 12px;">Could not load channels. Try disconnecting and reconnecting.</p>
            <% } else if (buffer.channels.length > 0) { %>
              <form method="POST" action="/integrations/buffer/channels">
                <label style="font-size: 13px; color: var(--text-secondary); display: block; margin-bottom: 8px;">Channels your agent can post to:</label>
                <div style="display: flex; flex-direction: column; gap: 6px; margin-bottom: 12px;">
                  <% buffer.channels.forEach(function(ch) { %>
                    <label style="display: flex; align-items: center; gap: 8px; font-size: 14px; cursor: pointer;">
                      <input type="checkbox" name="channels" value="<%= ch.id %>"
                        <%= (buffer.selected_channels.length === 0 || buffer.selected_channels.includes(ch.id)) ? 'checked' : '' %>>
                      <span><%= ch.name %></span>
                      <span style="font-size: 12px; color: var(--text-secondary);">— <%= ch.service %></span>
                    </label>
                  <% }); %>
                </div>
                <button type="submit" class="btn btn-sm" style="margin-bottom: 12px;">Save Channels</button>
              </form>
            <% } else { %>
              <p style="color: var(--text-secondary); font-size: 13px; margin-bottom: 12px;">No channels found. Connect social accounts in Buffer first.</p>
            <% } %>

            <form method="POST" action="/integrations/buffer/disconnect">
              <button type="submit" class="btn btn-danger btn-sm">Disconnect</button>
            </form>
          <% } else { %>
            <form method="POST" action="/integrations/buffer/connect">
              <p style="font-size: 14px; margin-bottom: 12px;">Connect your Buffer account so your agent can schedule and publish social media posts across Twitter, Instagram, LinkedIn, and more.</p>
              <div class="form-group">
                <label for="buffer_api_key">API Key</label>
                <input type="password" id="buffer_api_key" name="api_key" placeholder="Bearer token..." required>
                <div class="hint">Generate your API key at <a href="https://publish.buffer.com/settings/api" target="_blank" style="color: var(--accent);">publish.buffer.com/settings/api</a></div>
              </div>
              <button type="submit" class="btn">Connect</button>
            </form>
          <% } %>

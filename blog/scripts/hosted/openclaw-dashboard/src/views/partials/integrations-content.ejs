<script>
(function () {
  var modeEl = document.getElementById("email_filter_mode");
  if (!modeEl) return;

  var domainGroup = document.getElementById("filter-domain-group");
  var addressesGroup = document.getElementById("filter-addresses-group");
  var addressInput = document.getElementById("filter_address_input");
  var addBtn = document.getElementById("add-address-btn");
  var tagsContainer = document.getElementById("address-tags");
  var hiddenInput = document.getElementById("filter_addresses_hidden");

  var addresses = <%= JSON.stringify(email.filter_addresses || []) %>;

  function updateVisibility() {
    var mode = modeEl.value;
    domainGroup.style.display = mode === "domain" ? "block" : "none";
    addressesGroup.style.display = mode === "addresses" ? "block" : "none";
  }

  function renderTags() {
    tagsContainer.innerHTML = "";
    hiddenInput.value = addresses.join(",");
    addresses.forEach(function (addr, i) {
      var tag = document.createElement("span");
      tag.style.cssText = "display: inline-flex; align-items: center; gap: 4px; padding: 4px 10px; background: var(--tag-bg); color: var(--accent); border-radius: 12px; font-size: 13px;";
      tag.textContent = addr;
      var removeBtn = document.createElement("button");
      removeBtn.type = "button";
      removeBtn.textContent = "\u00d7";
      removeBtn.style.cssText = "border: none; background: none; color: var(--accent); cursor: pointer; font-size: 16px; padding: 0; line-height: 1;";
      removeBtn.onclick = function () {
        addresses.splice(i, 1);
        renderTags();
      };
      tag.appendChild(removeBtn);
      tagsContainer.appendChild(tag);
    });
  }

  function addAddress() {
    var val = addressInput.value.trim().toLowerCase();
    if (val && val.includes("@") && addresses.indexOf(val) === -1) {
      addresses.push(val);
      renderTags();
      addressInput.value = "";
    }
    addressInput.focus();
  }

  addBtn.addEventListener("click", addAddress);
  addressInput.addEventListener("keydown", function (e) {
    if (e.key === "Enter") { e.preventDefault(); addAddress(); }
  });
  modeEl.addEventListener("change", updateVisibility);

  updateVisibility();
  renderTags();
})();

// Gmail email rules — radio policy
(function () {
  var radios = document.querySelectorAll(".gmail-policy-radio");
  if (!radios.length) return;

  var domainsGroup = document.getElementById("gmail-domains-group");
  var addressesGroup = document.getElementById("gmail-addresses-group");
  var addressInput = document.getElementById("gmail_address_input");
  var addBtn = document.getElementById("gmail-add-address-btn");
  var tagsContainer = document.getElementById("gmail-address-tags");
  var hiddenInput = document.getElementById("gmail_filter_addresses_hidden");

  var addresses = <%= JSON.stringify((typeof gmailEmailPolicy !== 'undefined' && gmailEmailPolicy.addresses) || []) %>;

  function updateGmailVisibility() {
    var selected = document.querySelector('.gmail-policy-radio:checked');
    var policy = selected ? selected.value : "known";
    domainsGroup.style.display = policy === "domains" ? "block" : "none";
    addressesGroup.style.display = policy === "addresses" ? "block" : "none";
  }

  function renderGmailTags() {
    tagsContainer.innerHTML = "";
    hiddenInput.value = addresses.join(",");
    addresses.forEach(function (addr, i) {
      var tag = document.createElement("span");
      tag.style.cssText = "display: inline-flex; align-items: center; gap: 4px; padding: 4px 10px; background: var(--tag-bg); color: var(--accent); border-radius: 12px; font-size: 13px;";
      tag.textContent = addr;
      var removeBtn = document.createElement("button");
      removeBtn.type = "button";
      removeBtn.textContent = "\u00d7";
      removeBtn.style.cssText = "border: none; background: none; color: var(--accent); cursor: pointer; font-size: 16px; padding: 0; line-height: 1;";
      removeBtn.onclick = function () {
        addresses.splice(i, 1);
        renderGmailTags();
      };
      tag.appendChild(removeBtn);
      tagsContainer.appendChild(tag);
    });
  }

  function addGmailAddress() {
    var val = addressInput.value.trim().toLowerCase();
    if (val && val.includes("@") && addresses.indexOf(val) === -1) {
      addresses.push(val);
      renderGmailTags();
      addressInput.value = "";
    }
    addressInput.focus();
  }

  addBtn.addEventListener("click", addGmailAddress);
  addressInput.addEventListener("keydown", function (e) {
    if (e.key === "Enter") { e.preventDefault(); addGmailAddress(); }
  });
  radios.forEach(function (r) {
    r.addEventListener("change", updateGmailVisibility);
  });

  updateGmailVisibility();
  renderGmailTags();
})();

</script>

<script>
(function() {
  // Add "Test Connection" button to all connected integrations
  document.querySelectorAll('.integration-tile').forEach(function(tile) {
    var badge = tile.querySelector('.status-badge');
    if (!badge || !badge.classList.contains('status-connected')) return;

    // Determine integration type from the disconnect form action
    var disconnectForm = tile.querySelector('form[action*="/disconnect"]');
    if (!disconnectForm) return;
    var action = disconnectForm.getAttribute('action');
    var match = action.match(/\/integrations\/([^/]+)\/disconnect/);
    if (!match) return;
    var type = match[1];

    // Insert health check button before the disconnect form
    var wrapper = document.createElement('div');
    wrapper.style.cssText = 'margin-bottom: 12px; display: flex; align-items: center; gap: 8px;';
    wrapper.innerHTML = '<button type="button" class="btn btn-sm" style="background: transparent; border: 1px solid var(--border); color: var(--fg);">Test Connection</button>'
      + '<span class="health-result" style="font-size: 12px;"></span>';

    var hr = disconnectForm.previousElementSibling;
    if (hr && hr.tagName === 'HR') {
      hr.parentNode.insertBefore(wrapper, hr);
    } else {
      disconnectForm.parentNode.insertBefore(wrapper, disconnectForm);
    }

    var btn = wrapper.querySelector('button');
    var resultEl = wrapper.querySelector('.health-result');

    btn.addEventListener('click', function() {
      btn.disabled = true;
      btn.textContent = 'Testing...';
      resultEl.textContent = '';
      resultEl.style.color = '';

      fetch('/integrations/' + encodeURIComponent(type) + '/health-check', { method: 'POST' })
        .then(function(r) { return r.json(); })
        .then(function(d) {
          btn.disabled = false;
          btn.textContent = 'Test Connection';
          if (d.success) {
            resultEl.style.color = '#16A34A';
            resultEl.textContent = 'Connected (' + d.response_ms + 'ms)' + (d.detail ? ' — ' + d.detail : '');
          } else {
            resultEl.style.color = '#DC2626';
            resultEl.textContent = 'Failed: ' + (d.error || 'Unknown error');
          }
        })
        .catch(function() {
          btn.disabled = false;
          btn.textContent = 'Test Connection';
          resultEl.style.color = '#DC2626';
          resultEl.textContent = 'Request failed';
        });
    });
  });
})();
</script>

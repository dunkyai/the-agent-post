<nav class="sidebar">
  <div class="sidebar-brand">
    <a href="/getting-started" style="display: flex; align-items: center; text-decoration: none;">
      <img src="/mascot.webp" alt="OpenClaw" width="36" height="36" style="border-radius: 8px;">
    </a>
  </div>
  <ul class="sidebar-nav">
    <li><a href="/getting-started" class="<%= typeof active !== 'undefined' && active === 'getting-started' ? 'active' : '' %>">Getting Started</a></li>
    <li><a href="/settings" class="<%= typeof active !== 'undefined' && active === 'settings' ? 'active' : '' %>">Settings</a></li>
    <li><a href="/shortcuts" class="<%= typeof active !== 'undefined' && active === 'shortcuts' ? 'active' : '' %>">Shortcuts</a></li>
    <li><a href="/jobs" class="<%= typeof active !== 'undefined' && (active === 'jobs' || active === 'tasks') ? 'active' : '' %>">Jobs & Tasks</a></li>
    <li><a href="/logs" class="<%= typeof active !== 'undefined' && active === 'logs' ? 'active' : '' %>">Logs</a></li>
    <li><a href="/chat" class="<%= typeof active !== 'undefined' && active === 'chat' ? 'active' : '' %>">Chat with your AI</a></li>
  </ul>
  <div class="sidebar-footer">
    <form method="POST" action="/logout">
      <button type="submit" class="btn-logout">Logout</button>
    </form>
  </div>
</nav>
<script>
// Instant visual feedback on nav clicks
document.querySelectorAll('.sidebar-nav a').forEach(function(link) {
  link.addEventListener('click', function() {
    // Remove active from all, highlight clicked
    document.querySelectorAll('.sidebar-nav a').forEach(function(a) { a.classList.remove('active'); });
    this.classList.add('active');
    this.style.opacity = '0.7';
  });
});
</script>

<div id="bug-widget">
  <button id="bug-toggle" onclick="document.getElementById('bug-form').classList.toggle('open')">Report a Bug</button>
  <div id="bug-form">
    <div style="font-weight:600;font-size:14px;margin-bottom:8px;">Report a Bug</div>
    <textarea id="bug-input" rows="3" placeholder="Describe the issue..."></textarea>
    <div style="display:flex;gap:8px;align-items:center;margin-top:8px;">
      <button id="bug-submit" class="btn" onclick="submitBug()">Send</button>
      <span id="bug-status" style="font-size:12px;"></span>
    </div>
  </div>
</div>

<style>
  #bug-widget { position: fixed; right: 0; top: 50%; transform: translateY(-50%); z-index: 9999; }
  #bug-toggle {
    writing-mode: vertical-rl; text-orientation: mixed;
    border: none; padding: 12px 8px;
    background: var(--accent); color: #fff; cursor: pointer;
    font-size: 12px; font-weight: 600; font-family: inherit;
    border-radius: 8px 0 0 8px;
    box-shadow: -2px 0 8px rgba(0,0,0,0.15);
    transition: background 0.2s;
    letter-spacing: 0.5px;
  }
  #bug-toggle:hover { background: var(--accent-light); }
  #bug-form {
    display: none; position: absolute; right: 36px; top: 50%; transform: translateY(-50%);
    width: 300px; background: #fff; border: 1px solid var(--rule-light);
    border-radius: 10px; padding: 16px;
    box-shadow: 0 4px 16px rgba(0,0,0,0.12);
  }
  #bug-form.open { display: block; }
  #bug-input {
    width: 100%; padding: 8px 10px; border: 1px solid var(--rule-light);
    border-radius: 6px; font-size: 13px; font-family: inherit;
    resize: vertical; color: var(--fg);
  }
  #bug-input:focus { outline: none; border-color: var(--accent); }
  #bug-form .btn { font-size: 13px; padding: 6px 16px; }
</style>

<script>
  function submitBug() {
    var input = document.getElementById('bug-input');
    var status = document.getElementById('bug-status');
    var btn = document.getElementById('bug-submit');
    var msg = input.value.trim();
    if (!msg) { status.textContent = 'Please describe the issue.'; status.style.color = 'var(--danger)'; return; }
    btn.disabled = true;
    status.textContent = 'Sending...';
    status.style.color = 'var(--text-secondary)';
    fetch('/bug-report', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ message: msg })
    })
    .then(function(r) { return r.json(); })
    .then(function(data) {
      if (data.success) {
        status.textContent = 'Sent — thank you!';
        status.style.color = 'var(--success)';
        input.value = '';
        setTimeout(function() { document.getElementById('bug-form').classList.remove('open'); status.textContent = ''; }, 2000);
      } else {
        status.textContent = data.error || 'Failed to send.';
        status.style.color = 'var(--danger)';
      }
    })
    .catch(function() { status.textContent = 'Failed to send.'; status.style.color = 'var(--danger)'; })
    .finally(function() { btn.disabled = false; });
  }
</script>

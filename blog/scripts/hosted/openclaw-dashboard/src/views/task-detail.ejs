<%- include('partials/head', { title: 'Task ' + task.task_id }) %>
<div class="app">
  <%- include('partials/nav', { active: 'tasks' }) %>
  <div class="main">
    <div style="margin-bottom: 16px;">
      <a href="/tasks" style="color: var(--accent); text-decoration: none; font-size: 14px;">&larr; Back to Tasks</a>
    </div>

    <div class="card">
      <div class="integration-header">
        <h2 style="margin: 0; font-size: 18px; font-family: monospace;"><%= task.task_id %></h2>
        <span class="status-badge task-status-<%= task.status %>">
          <%= task.status.replace('_', ' ') %>
        </span>
      </div>
    </div>

    <!-- Input -->
    <div class="card">
      <h3 style="margin-top: 0;">Input</h3>
      <div style="font-size: 13px; color: var(--text-secondary); margin-bottom: 8px;">
        <span class="task-channel-badge"><%= task.input.source_channel %></span>
        <span style="margin-left: 8px;" class="local-time" data-utc="<%= task.created_at %>"><%= task.created_at %></span>
      </div>
      <div style="background: var(--bg-secondary, #f5f5f5); padding: 12px; border-radius: 6px; white-space: pre-wrap; font-size: 14px; max-height: 300px; overflow-y: auto;"><%- task.input.raw_input %></div>
    </div>

    <!-- Execution -->
    <% if (task.execution.model || task.execution.started_at) { %>
    <div class="card">
      <h3 style="margin-top: 0;">Execution</h3>
      <div style="font-size: 13px; color: var(--text-secondary); display: grid; grid-template-columns: auto 1fr; gap: 4px 16px;">
        <% if (task.execution.model) { %>
          <strong>Model:</strong> <span><%= task.execution.provider %>/<%= task.execution.model %></span>
        <% } %>
        <% if (task.execution.started_at) { %>
          <strong>Started:</strong> <span class="local-time" data-utc="<%= task.execution.started_at %>"><%= task.execution.started_at %></span>
        <% } %>
        <% if (task.execution.completed_at) { %>
          <strong>Completed:</strong> <span class="local-time" data-utc="<%= task.execution.completed_at %>"><%= task.execution.completed_at %></span>
        <% } %>
        <% if (task.execution.duration_ms != null) { %>
          <strong>Duration:</strong> <span><%= (task.execution.duration_ms / 1000).toFixed(1) %>s</span>
        <% } %>
        <% if (task.execution.tool_calls_count != null) { %>
          <strong>Tool calls:</strong> <span><%= task.execution.tool_calls_count %></span>
        <% } %>
      </div>
    </div>
    <% } %>

    <!-- Result -->
    <% if (task.output.result || task.output.error) { %>
    <div class="card">
      <h3 style="margin-top: 0;"><%= task.output.error ? 'Error' : 'Result' %></h3>
      <div style="background: var(--bg-secondary, #f5f5f5); padding: 12px; border-radius: 6px; white-space: pre-wrap; font-size: 14px; max-height: 500px; overflow-y: auto; <%= task.output.error ? 'color: var(--danger);' : '' %>"><%- task.output.error || task.output.result %></div>
    </div>
    <% } %>

    <!-- Execution Log -->
    <% if (log.length > 0) { %>
    <div class="card">
      <h3 style="margin-top: 0;">Execution Log (<%= log.length %> tool call<%= log.length !== 1 ? 's' : '' %>)</h3>
      <% log.forEach(function(entry, i) { %>
        <details style="margin-bottom: 8px; border: 1px solid var(--border, #e0e0e0); border-radius: 6px; padding: 0;">
          <summary style="padding: 8px 12px; cursor: pointer; font-size: 13px; display: flex; align-items: center; gap: 8px;">
            <span style="font-weight: 600; font-family: monospace;"><%= entry.tool %></span>
            <span style="color: var(--text-secondary); font-size: 12px;"><%= entry.duration_ms %>ms</span>
          </summary>
          <div style="padding: 8px 12px; border-top: 1px solid var(--border, #e0e0e0);">
            <div style="margin-bottom: 8px;">
              <div style="font-size: 11px; font-weight: 600; text-transform: uppercase; color: var(--text-secondary); margin-bottom: 4px;">Input</div>
              <pre style="background: var(--bg-secondary, #f5f5f5); padding: 8px; border-radius: 4px; font-size: 12px; overflow-x: auto; max-height: 200px; margin: 0;"><%= JSON.stringify(entry.input, null, 2) %></pre>
            </div>
            <div>
              <div style="font-size: 11px; font-weight: 600; text-transform: uppercase; color: var(--text-secondary); margin-bottom: 4px;">Output</div>
              <pre style="background: var(--bg-secondary, #f5f5f5); padding: 8px; border-radius: 4px; font-size: 12px; overflow-x: auto; max-height: 200px; margin: 0;"><%= entry.output.length > 2000 ? entry.output.slice(0, 2000) + '...' : entry.output %></pre>
            </div>
          </div>
        </details>
      <% }); %>
    </div>
    <% } %>
  </div>
</div>

<style>
.task-channel-badge {
  font-size: 11px;
  padding: 2px 8px;
  border-radius: 4px;
  background: var(--bg-secondary, #f0f0f0);
  color: var(--text-secondary);
  text-transform: uppercase;
  font-weight: 500;
}
.task-status-pending { background: var(--bg-secondary, #e0e0e0); color: var(--text-secondary); }
.task-status-processing { background: #dbeafe; color: #1d4ed8; }
.task-status-awaiting_confirmation { background: #fef3c7; color: #92400e; }
.task-status-completed { background: #d1fae5; color: #065f46; }
.task-status-failed { background: #fee2e2; color: #991b1b; }
.task-status-cancelled { background: var(--bg-secondary, #e0e0e0); color: var(--text-secondary); }

details summary::-webkit-details-marker { display: none; }
details summary::marker { content: ''; }
details summary::before {
  content: '\25B6';
  display: inline-block;
  font-size: 10px;
  transition: transform 0.15s;
}
details[open] summary::before {
  transform: rotate(90deg);
}
</style>

<script>
(function() {
  var userTimezone = "<%= timezone %>";
  function formatLocal(utcStr, tz) {
    try {
      var normalized = utcStr.indexOf('Z') === -1 && utcStr.indexOf('+') === -1 ? utcStr.replace(' ', 'T') + 'Z' : utcStr;
      var d = new Date(normalized);
      if (isNaN(d.getTime())) return utcStr;
      return d.toLocaleString('en-US', { timeZone: tz, month: 'short', day: 'numeric', hour: 'numeric', minute: '2-digit', second: '2-digit', hour12: true });
    } catch (e) { return utcStr; }
  }
  document.querySelectorAll('.local-time').forEach(function(el) {
    var utc = el.getAttribute('data-utc');
    if (utc) el.textContent = formatLocal(utc, userTimezone);
  });
})();
</script>

<%- include('partials/foot') %>

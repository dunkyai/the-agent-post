<%- include('partials/head', { title: 'Login' }) %>
<div class="login-page">
  <div class="login-card">
    <h1>OpenClaw</h1>

    <% if (sent) { %>
      <div class="login-success">
        <div style="font-size: 32px; margin-bottom: 12px;">&#9993;</div>
        <p style="font-size: 18px; font-weight: 600; margin-bottom: 8px; color: var(--fg);">Check your email</p>
        <p style="color: var(--text-secondary); font-size: 14px; margin-bottom: 0;">If you have an account, you will receive an email from us with your magic link.</p>
      </div>
      <a href="/login" class="btn btn-secondary" style="width: 100%; text-align: center; display: block; margin-top: 20px; text-decoration: none;">Back to login</a>
    <% } else { %>
      <p>Enter your email to receive a sign-in link</p>

      <% if (error) { %>
        <div class="login-error"><%= error %></div>
      <% } %>

      <form method="POST" action="/login/magic-link">
        <div class="form-group" style="margin-bottom: 20px;">
          <input type="email" id="email" name="email" placeholder="you@example.com" required autofocus style="padding: 12px 16px; font-size: 15px;">
        </div>
        <button type="submit" class="btn" style="width: 100%; padding: 12px; font-size: 15px;">Send Sign-in Link</button>
      </form>
    <% } %>
  </div>
</div>
<%- include('partials/foot') %>

<%- include('partials/head', { title: 'Login' }) %>
<div class="login-page">
  <div class="login-card">
    <h1>OpenClaw</h1>

    <% if (sent) { %>
      <div class="login-success">
        <p style="font-size: 18px; margin-bottom: 8px;">Check your email</p>
        <p style="color: var(--text-dim); font-size: 14px;">If you have an account, you will receive an email from us with your magic link.</p>
      </div>
      <a href="/login" class="btn" style="width: 100%; text-align: center; display: block; margin-top: 16px; text-decoration: none;">Back to login</a>
    <% } else { %>
      <p>Enter your email to receive a sign-in link</p>

      <% if (error) { %>
        <div class="login-error"><%= error %></div>
      <% } %>

      <form method="POST" action="/login/magic-link">
        <div class="form-group">
          <label for="email">Email</label>
          <input type="email" id="email" name="email" placeholder="you@example.com" required autofocus>
        </div>
        <button type="submit" class="btn" style="width:100%">Send Sign-in Link</button>
      </form>
    <% } %>
  </div>
</div>
<%- include('partials/foot') %>

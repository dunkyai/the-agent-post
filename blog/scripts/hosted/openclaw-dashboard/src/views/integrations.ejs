<%- include('partials/head', { title: 'Integrations' }) %>
<div class="app">
  <%- include('partials/nav', { active: 'integrations' }) %>
  <div class="main">
    <h2>Integrations</h2>
    <%- include('partials/flash', { flash }) %>

    <!-- Telegram (disabled) -->
    <details class="card card-collapsible" style="opacity: 0.5; pointer-events: none;">
      <summary class="integration-toggle">
        <div class="integration-header">
          <h3>Telegram <span style="font-size: 12px; font-weight: normal; color: var(--text-secondary);">(Coming soon)</span></h3>
          <span class="status-badge status-disconnected">disabled</span>
        </div>
        <span class="toggle-arrow"></span>
      </summary>
      <div class="integration-body">
      </div>
    </details>

    <!-- Slack -->
    <details class="card card-collapsible">
      <summary class="integration-toggle">
        <div class="integration-header">
          <h3>Slack</h3>
          <span class="status-badge status-<%= slack.status %>"><%= slack.status %></span>
        </div>
        <span class="toggle-arrow"></span>
      </summary>
      <div class="integration-body">
        <% if (slack.error_message) { %>
          <p style="color: var(--danger); font-size: 13px; margin-bottom: 12px;"><%= slack.error_message %></p>
        <% } %>

        <% if (slack.status === 'connected') { %>
          <div style="margin-bottom: 12px;">
            <label style="font-size: 13px; color: var(--muted);">Connected Workspace</label>
            <div style="margin-top: 4px;">
              <code style="font-size: 14px; padding: 6px 10px; background: var(--bg); border: 1px solid var(--border); border-radius: 4px;"><%= slack.team_name || 'Unknown' %></code>
            </div>
          </div>
          <form method="POST" action="/integrations/slack/disconnect">
            <button type="submit" class="btn btn-danger">Disconnect</button>
          </form>
        <% } else { %>
          <form method="POST" action="/integrations/slack/connect">
            <p style="font-size: 14px; margin-bottom: 12px;">Connect your Slack workspace to chat with your agent in any channel it's invited to.</p>
            <button type="submit" class="btn">Connect to Slack</button>
          </form>
        <% } %>
      </div>
    </details>

    <!-- Email (LobsterMail) -->
    <details class="card card-collapsible">
      <summary class="integration-toggle">
        <div class="integration-header">
          <h3>Email</h3>
          <span class="status-badge status-<%= email.status %>"><%= email.status %></span>
        </div>
        <span class="toggle-arrow"></span>
      </summary>
      <div class="integration-body">
        <% if (email.error_message) { %>
          <p style="color: var(--danger); font-size: 13px; margin-bottom: 12px;"><%= email.error_message %></p>
        <% } %>

        <% if (email.status === 'connected') { %>
          <div style="margin-bottom: 12px;">
            <label style="font-size: 13px; color: var(--muted);">Agent Email Address</label>
            <div style="display: flex; align-items: center; gap: 8px; margin-top: 4px;">
              <code id="email-address" style="font-size: 14px; padding: 6px 10px; background: var(--bg); border: 1px solid var(--border); border-radius: 4px; flex: 1;"><%= email.email_address %></code>
              <button type="button" onclick="navigator.clipboard.writeText(document.getElementById('email-address').textContent).then(() => this.textContent = 'Copied!').catch(() => {}); setTimeout(() => this.textContent = 'Copy', 1500);" class="btn" style="padding: 6px 12px; font-size: 13px;">Copy</button>
            </div>
            <div class="hint" style="margin-top: 6px;">Send emails to this address and your agent will respond via AI. Replies require a Tier 1+ LobsterMail API key.</div>
          </div>
          <form method="POST" action="/integrations/email/filter" style="margin-bottom: 12px; padding-top: 12px; border-top: 1px solid var(--rule-light);">
            <div class="form-group">
              <label for="email_filter_mode">Filter Incoming Emails</label>
              <select id="email_filter_mode" name="filter_mode">
                <option value="all" <%= email.filter_mode === 'all' ? 'selected' : '' %>>Allow all</option>
                <option value="domain" <%= email.filter_mode === 'domain' ? 'selected' : '' %>>Allow only from a domain</option>
                <option value="addresses" <%= email.filter_mode === 'addresses' ? 'selected' : '' %>>Allow only specific addresses</option>
              </select>
            </div>

            <div id="filter-domain-group" class="form-group" style="display: none;">
              <label for="filter_domain">Allowed Domain</label>
              <input type="text" id="filter_domain" name="filter_domain" value="<%= email.filter_domain || '' %>" placeholder="e.g. acme.com">
              <div class="hint">Only emails from @this-domain will be processed</div>
            </div>

            <div id="filter-addresses-group" style="display: none;">
              <div class="form-group">
                <label>Allowed Addresses</label>
                <div style="display: flex; gap: 8px;">
                  <input type="email" id="filter_address_input" placeholder="alice@example.com" style="flex: 1;">
                  <button type="button" id="add-address-btn" class="btn" style="padding: 8px 16px;">Add</button>
                </div>
              </div>
              <div id="address-tags" style="display: flex; flex-wrap: wrap; gap: 6px; margin-bottom: 12px;"></div>
              <input type="hidden" id="filter_addresses_hidden" name="filter_addresses" value="">
            </div>

            <button type="submit" class="btn">Save Filter</button>
          </form>

          <form method="POST" action="/integrations/email/disconnect">
            <button type="submit" class="btn btn-danger">Disconnect</button>
          </form>
        <% } else { %>
          <form method="POST" action="/integrations/email/connect">
            <div class="form-group">
              <label for="email_api_key">LobsterMail API Key <span style="color: var(--muted); font-weight: normal;">(optional)</span></label>
              <input type="password" id="email_api_key" name="api_key" placeholder="lm_sk_live_...">
              <div class="hint">Leave blank to auto-provision a free inbox (receive only). Paste a Tier 1+ key to enable replies.</div>
            </div>
            <button type="submit" class="btn">Connect Email</button>
          </form>
        <% } %>
      </div>
    </details>

    <!-- Google (multi-account) -->
    <details class="card card-collapsible">
      <summary class="integration-toggle">
        <div class="integration-header">
          <h3>Google</h3>
          <% if (googleAccounts.length > 0) { %>
            <span class="status-badge status-connected"><%= googleAccounts.length %> account<%= googleAccounts.length > 1 ? 's' : '' %></span>
          <% } else { %>
            <span class="status-badge status-disconnected">disconnected</span>
          <% } %>
        </div>
        <span class="toggle-arrow"></span>
      </summary>
      <div class="integration-body">
        <% for (const acct of googleAccounts) { %>
          <div style="padding: 12px 0; border-bottom: 1px solid var(--rule-light);">
            <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 8px;">
              <code style="font-size: 14px; padding: 4px 8px; background: var(--bg); border: 1px solid var(--rule-light); border-radius: 4px;"><%= acct.email %></code>
              <form method="POST" action="/integrations/google/disconnect" style="margin: 0;">
                <input type="hidden" name="account" value="<%= acct.email %>">
                <button type="submit" class="btn btn-danger btn-sm">Disconnect</button>
              </form>
            </div>
            <div style="display: flex; gap: 6px; flex-wrap: wrap;">
              <% for (const svc of acct.services) { %>
                <% if (svc === 'gmail_send') { %>
                  <span class="status-badge status-connected">Draft & Send</span>
                <% } else { %>
                  <span class="status-badge status-connected"><%= svc.charAt(0).toUpperCase() + svc.slice(1) %></span>
                <% } %>
              <% } %>
            </div>
          </div>
        <% } %>

        <div style="<%= googleAccounts.length > 0 ? 'padding-top: 12px;' : '' %>">
          <form method="POST" action="/integrations/google/connect">
            <div class="form-group">
              <label>Select Google services to connect:</label>
              <div style="display: flex; flex-direction: column; gap: 8px; margin-top: 8px;">
                <label style="display: flex; align-items: center; gap: 8px; font-size: 14px; cursor: pointer;">
                  <input type="checkbox" name="services" value="gmail" checked>
                  <strong>Gmail</strong> &mdash; Read and label emails
                </label>
                <label style="display: flex; align-items: center; gap: 8px; font-size: 14px; cursor: pointer; padding-left: 28px;">
                  <input type="checkbox" name="services" value="gmail_send">
                  <strong>Draft &amp; Send</strong> &mdash; Create drafts and send emails
                </label>
                <label style="display: flex; align-items: center; gap: 8px; font-size: 14px; cursor: pointer;">
                  <input type="checkbox" name="services" value="calendar">
                  <strong>Calendar</strong> &mdash; View and create events
                </label>
                <label style="display: flex; align-items: center; gap: 8px; font-size: 14px; cursor: pointer;">
                  <input type="checkbox" name="services" value="drive">
                  <strong>Drive</strong> &mdash; Search and read files
                </label>
                <label style="display: flex; align-items: center; gap: 8px; font-size: 14px; cursor: pointer;">
                  <input type="checkbox" name="services" value="contacts">
                  <strong>Contacts</strong> &mdash; Search contacts
                </label>
              </div>
              <div class="hint" style="margin-top: 8px;">At least one service must be selected. Your agent will only access services you enable.</div>
            </div>
            <button type="submit" class="btn"><%= googleAccounts.length > 0 ? 'Add Another Google Account' : 'Connect with Google' %></button>
          </form>
        </div>
      </div>
    </details>
    <!-- Supabase -->
    <details class="card card-collapsible">
      <summary class="integration-toggle">
        <div class="integration-header">
          <h3>Supabase</h3>
          <span class="status-badge status-<%= supabase.status %>"><%= supabase.status %></span>
        </div>
        <span class="toggle-arrow"></span>
      </summary>
      <div class="integration-body">
        <% if (supabase.error_message) { %>
          <p style="color: var(--danger); font-size: 13px; margin-bottom: 12px;"><%= supabase.error_message %></p>
        <% } %>

        <% if (supabase.status === 'connected') { %>
          <div style="margin-bottom: 12px;">
            <label style="font-size: 13px; color: var(--muted);">Project URL</label>
            <div style="margin-top: 4px;">
              <code style="font-size: 14px; padding: 6px 10px; background: var(--bg); border: 1px solid var(--border); border-radius: 4px;"><%= supabase.project_url %></code>
            </div>
          </div>
          <form method="POST" action="/integrations/supabase/permissions" style="margin-bottom: 12px; padding-top: 12px; border-top: 1px solid var(--rule-light);">
            <div class="form-group">
              <label>Agent Permissions</label>
              <div style="display: flex; flex-direction: column; gap: 8px; margin-top: 8px;">
                <label style="display: flex; align-items: center; gap: 8px; font-size: 14px; cursor: pointer;">
                  <input type="checkbox" name="permissions" value="read" checked disabled>
                  <strong>Read</strong> &mdash; Query and list tables
                </label>
                <label style="display: flex; align-items: center; gap: 8px; font-size: 14px; cursor: pointer;">
                  <input type="checkbox" name="permissions" value="insert" <%= supabase.permissions.includes('insert') ? 'checked' : '' %>>
                  <strong>Insert</strong> &mdash; Add new records
                </label>
                <label style="display: flex; align-items: center; gap: 8px; font-size: 14px; cursor: pointer;">
                  <input type="checkbox" name="permissions" value="update" <%= supabase.permissions.includes('update') ? 'checked' : '' %>>
                  <strong>Update</strong> &mdash; Modify existing records
                </label>
              </div>
            </div>
            <button type="submit" class="btn btn-sm">Save Permissions</button>
          </form>
          <form method="POST" action="/integrations/supabase/disconnect">
            <button type="submit" class="btn btn-danger">Disconnect</button>
          </form>
        <% } else { %>
          <form method="POST" action="/integrations/supabase/connect">
            <p style="font-size: 14px; margin-bottom: 12px;">Connect your Supabase project so your agent can query your database. Here's where to <a href="https://theagentpost.co/guides/find-your-api-key#supabase" target="_blank" style="color: var(--accent); text-decoration: underline;">find your Project URL and API key</a></p>
            <div class="form-group">
              <label for="supabase_project_url">Project URL</label>
              <input type="url" id="supabase_project_url" name="project_url" placeholder="https://your-project.supabase.co" required>
              <div class="hint">Find this in your Supabase dashboard under Settings &rarr; API</div>
            </div>
            <div class="form-group">
              <label for="supabase_api_key">API Key</label>
              <input type="password" id="supabase_api_key" name="api_key" placeholder="eyJhbGciOiJIUzI1NiIs..." required>
              <div class="hint">Use the <code>anon</code> key for read-only, or <code>service_role</code> key if you want insert/update access</div>
            </div>
            <div class="form-group">
              <label>Agent Permissions</label>
              <div style="display: flex; flex-direction: column; gap: 8px; margin-top: 8px;">
                <label style="display: flex; align-items: center; gap: 8px; font-size: 14px; cursor: pointer;">
                  <input type="checkbox" name="permissions" value="read" checked disabled>
                  <strong>Read</strong> &mdash; Query and list tables
                </label>
                <label style="display: flex; align-items: center; gap: 8px; font-size: 14px; cursor: pointer;">
                  <input type="checkbox" name="permissions" value="insert">
                  <strong>Insert</strong> &mdash; Add new records
                </label>
                <label style="display: flex; align-items: center; gap: 8px; font-size: 14px; cursor: pointer;">
                  <input type="checkbox" name="permissions" value="update">
                  <strong>Update</strong> &mdash; Modify existing records
                </label>
              </div>
            </div>
            <button type="submit" class="btn">Connect</button>
          </form>
        <% } %>
      </div>
    </details>

    <!-- Airtable -->
    <details class="card card-collapsible">
      <summary class="integration-toggle">
        <div class="integration-header">
          <h3>Airtable</h3>
          <span class="status-badge status-<%= airtable.status %>"><%= airtable.status %></span>
        </div>
        <span class="toggle-arrow"></span>
      </summary>
      <div class="integration-body">
        <% if (airtable.error_message) { %>
          <p style="color: var(--danger); font-size: 13px; margin-bottom: 12px;"><%= airtable.error_message %></p>
        <% } %>

        <% if (airtable.status === 'connected') { %>
          <div style="margin-bottom: 12px;">
            <p style="font-size: 14px;">Your Airtable account is connected. Your agent can list bases, read and write records.</p>
          </div>
          <form method="POST" action="/integrations/airtable/disconnect">
            <button type="submit" class="btn btn-danger">Disconnect</button>
          </form>
        <% } else { %>
          <form method="POST" action="/integrations/airtable/connect">
            <p style="font-size: 14px; margin-bottom: 12px;">Connect your Airtable account so your agent can read and write to your bases.</p>
            <button type="submit" class="btn">Connect to Airtable</button>
          </form>
        <% } %>
      </div>
    </details>
  </div>
</div>
<script>
(function () {
  var modeEl = document.getElementById("email_filter_mode");
  if (!modeEl) return;

  var domainGroup = document.getElementById("filter-domain-group");
  var addressesGroup = document.getElementById("filter-addresses-group");
  var addressInput = document.getElementById("filter_address_input");
  var addBtn = document.getElementById("add-address-btn");
  var tagsContainer = document.getElementById("address-tags");
  var hiddenInput = document.getElementById("filter_addresses_hidden");

  var addresses = <%= JSON.stringify(email.filter_addresses || []) %>;

  function updateVisibility() {
    var mode = modeEl.value;
    domainGroup.style.display = mode === "domain" ? "block" : "none";
    addressesGroup.style.display = mode === "addresses" ? "block" : "none";
  }

  function renderTags() {
    tagsContainer.innerHTML = "";
    hiddenInput.value = addresses.join(",");
    addresses.forEach(function (addr, i) {
      var tag = document.createElement("span");
      tag.style.cssText = "display: inline-flex; align-items: center; gap: 4px; padding: 4px 10px; background: var(--tag-bg); color: var(--accent); border-radius: 12px; font-size: 13px;";
      tag.textContent = addr;
      var removeBtn = document.createElement("button");
      removeBtn.type = "button";
      removeBtn.textContent = "\u00d7";
      removeBtn.style.cssText = "border: none; background: none; color: var(--accent); cursor: pointer; font-size: 16px; padding: 0; line-height: 1;";
      removeBtn.onclick = function () {
        addresses.splice(i, 1);
        renderTags();
      };
      tag.appendChild(removeBtn);
      tagsContainer.appendChild(tag);
    });
  }

  function addAddress() {
    var val = addressInput.value.trim().toLowerCase();
    if (val && val.includes("@") && addresses.indexOf(val) === -1) {
      addresses.push(val);
      renderTags();
      addressInput.value = "";
    }
    addressInput.focus();
  }

  addBtn.addEventListener("click", addAddress);
  addressInput.addEventListener("keydown", function (e) {
    if (e.key === "Enter") { e.preventDefault(); addAddress(); }
  });
  modeEl.addEventListener("change", updateVisibility);

  updateVisibility();
  renderTags();
})();
</script>
<%- include('partials/foot') %>

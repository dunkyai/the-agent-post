<%- include('partials/head', { title: 'Integrations' }) %>
<div class="app">
  <%- include('partials/nav', { active: 'integrations' }) %>
  <div class="main" style="max-width: 900px;">
    <h2>Integrations</h2>
    <%- include('partials/flash', { flash }) %>

    <div class="integration-grid">

      <!-- Slack -->
      <details class="integration-tile">
        <summary class="integration-tile-summary">
          <span class="integration-icon" style="background: #4A154B;"><img src="/logos/slack.svg" alt="Slack" width="24" height="24"></span>
          <div class="integration-tile-info">
            <h3>Slack</h3>
            <p>Chat with your agent in Slack channels</p>
          </div>
          <span class="status-badge status-<%= slack.status %>"><%= slack.status %></span>
        </summary>
        <div class="integration-tile-body">
          <% if (slack.error_message) { %>
            <p style="color: var(--danger); font-size: 13px; margin-bottom: 12px;"><%= slack.error_message %></p>
          <% } %>

          <% if (slack.status === 'connected') { %>
            <div style="margin-bottom: 12px;">
              <label style="font-size: 13px; color: var(--text-secondary);">Connected Workspace</label>
              <div style="margin-top: 4px;">
                <code style="font-size: 14px; padding: 6px 10px; background: var(--bg); border: 1px solid var(--rule-light); border-radius: 4px;"><%= slack.team_name || 'Unknown' %></code>
              </div>
            </div>
            <hr style="border: none; border-top: 1px solid var(--rule-light); margin: 16px 0;">
            <form method="POST" action="/integrations/slack/approval">
              <h4 style="font-size: 14px; margin-bottom: 8px;">Access Control</h4>
              <label style="display: flex; align-items: center; gap: 8px; font-size: 13px; cursor: pointer; margin-bottom: 10px;">
                <input type="checkbox" name="approval_enabled" <%= slack.approval_enabled ? 'checked' : '' %>>
                Require my approval for other users' requests
              </label>
              <div style="margin-bottom: 10px;">
                <label style="font-size: 13px; color: var(--text-secondary);">Owner Slack User ID</label>
                <input type="text" name="owner_user_id" value="<%= slack.owner_user_id %>" placeholder="Auto-detected on first @mention" style="width: 100%; margin-top: 4px; padding: 6px 10px; font-size: 13px; border: 1px solid var(--rule-light); border-radius: 4px; background: var(--bg); color: var(--text);">
                <span style="font-size: 11px; color: var(--text-secondary);">Auto-set when you install Slack or first @mention the bot. Find yours in Slack: Profile → ⋯ → Copy member ID.</span>
              </div>
              <button type="submit" class="btn btn-sm">Save</button>
            </form>

            <hr style="border: none; border-top: 1px solid var(--rule-light); margin: 16px 0;">
            <form method="POST" action="/integrations/slack/disconnect">
              <button type="submit" class="btn btn-danger btn-sm">Disconnect</button>
            </form>
          <% } else { %>
            <form method="POST" action="/integrations/slack/connect">
              <p style="font-size: 14px; margin-bottom: 12px;">Connect your Slack workspace to chat with your agent in any channel it's invited to.</p>
              <button type="submit" class="btn">Connect to Slack</button>
            </form>
          <% } %>
        </div>
      </details>

      <!-- Email (LobsterMail) — hidden from UI, functionality preserved -->
      <!-- To re-enable: remove the false condition wrapping this block -->
      <% if (false) { %>
      <details class="integration-tile">
        <summary class="integration-tile-summary">
          <span class="integration-icon" style="background: #EA4335;"><img src="/logos/email.svg" alt="Email" width="24" height="24"></span>
          <div class="integration-tile-info">
            <h3>Email</h3>
            <p>Send and receive email as your agent</p>
          </div>
          <span class="status-badge status-<%= email.status %>"><%= email.status %></span>
        </summary>
        <div class="integration-tile-body">
          <% if (email.error_message) { %>
            <p style="color: var(--danger); font-size: 13px; margin-bottom: 12px;"><%= email.error_message %></p>
          <% } %>

          <% if (email.status === 'connected') { %>
            <div style="margin-bottom: 12px;">
              <label style="font-size: 13px; color: var(--text-secondary);">Agent Email Address</label>
              <div style="display: flex; align-items: center; gap: 8px; margin-top: 4px;">
                <code id="email-address" style="font-size: 14px; padding: 6px 10px; background: var(--bg); border: 1px solid var(--rule-light); border-radius: 4px; flex: 1;"><%= email.email_address %></code>
                <button type="button" onclick="navigator.clipboard.writeText(document.getElementById('email-address').textContent).then(() => this.textContent = 'Copied!').catch(() => {}); setTimeout(() => this.textContent = 'Copy', 1500);" class="btn btn-sm" style="padding: 6px 12px; font-size: 13px;">Copy</button>
              </div>
              <div class="hint" style="margin-top: 6px; font-size: 12px; color: var(--text-secondary);">Send emails to this address and your agent will respond via AI. Replies require a Tier 1+ LobsterMail API key.</div>
            </div>
            <form method="POST" action="/integrations/email/filter" style="margin-bottom: 12px; padding-top: 12px; border-top: 1px solid var(--rule-light);">
              <div class="form-group">
                <label for="email_filter_mode">Filter Incoming Emails</label>
                <select id="email_filter_mode" name="filter_mode">
                  <option value="all" <%= email.filter_mode === 'all' ? 'selected' : '' %>>Allow all</option>
                  <option value="domain" <%= email.filter_mode === 'domain' ? 'selected' : '' %>>Allow only from a domain</option>
                  <option value="addresses" <%= email.filter_mode === 'addresses' ? 'selected' : '' %>>Allow only specific addresses</option>
                </select>
              </div>

              <div id="filter-domain-group" class="form-group" style="display: none;">
                <label for="filter_domain">Allowed Domain</label>
                <input type="text" id="filter_domain" name="filter_domain" value="<%= email.filter_domain || '' %>" placeholder="e.g. acme.com">
                <div class="hint">Only emails from @this-domain will be processed</div>
              </div>

              <div id="filter-addresses-group" style="display: none;">
                <div class="form-group">
                  <label>Allowed Addresses</label>
                  <div style="display: flex; gap: 8px;">
                    <input type="email" id="filter_address_input" placeholder="alice@example.com" style="flex: 1;">
                    <button type="button" id="add-address-btn" class="btn btn-sm" style="padding: 8px 16px;">Add</button>
                  </div>
                </div>
                <div id="address-tags" style="display: flex; flex-wrap: wrap; gap: 6px; margin-bottom: 12px;"></div>
                <input type="hidden" id="filter_addresses_hidden" name="filter_addresses" value="">
              </div>

              <button type="submit" class="btn btn-sm">Save Filter</button>
            </form>

            <form method="POST" action="/integrations/email/disconnect">
              <button type="submit" class="btn btn-danger btn-sm">Disconnect</button>
            </form>
          <% } else { %>
            <form method="POST" action="/integrations/email/connect">
              <div class="form-group">
                <label for="email_api_key">LobsterMail API Key <span style="color: var(--text-secondary); font-weight: normal;">(optional)</span></label>
                <input type="password" id="email_api_key" name="api_key" placeholder="lm_sk_live_...">
                <div class="hint">Leave blank to auto-provision a free inbox (receive only). Paste a Tier 1+ key to enable replies.</div>
              </div>
              <button type="submit" class="btn">Connect Email</button>
            </form>
          <% } %>
        </div>
      </details>
      <% } %>

      <!-- Google -->
      <details class="integration-tile">
        <summary class="integration-tile-summary">
          <span class="integration-icon" style="background: #4285F4;"><img src="/logos/google.svg" alt="Google" width="24" height="24"></span>
          <div class="integration-tile-info">
            <h3>Google</h3>
            <p>Gmail, Calendar, Drive, Docs, Sheets</p>
          </div>
          <% if (googleAccounts.length > 0) { %>
            <span class="status-badge status-connected"><%= googleAccounts.length %> account<%= googleAccounts.length > 1 ? 's' : '' %></span>
          <% } else { %>
            <span class="status-badge status-disconnected">disconnected</span>
          <% } %>
        </summary>
        <div class="integration-tile-body">
          <% const allAvailableServices = ['gmail', 'gmail_send', 'calendar', 'drive', 'contacts', 'docs', 'sheets']; %>
          <% for (const acct of googleAccounts) { %>
            <% const missingServices = allAvailableServices.filter(s => !acct.services.includes(s)); %>
            <div style="padding: 12px 0; border-bottom: 1px solid var(--rule-light);">
              <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 8px;">
                <code style="font-size: 14px; padding: 4px 8px; background: var(--bg); border: 1px solid var(--rule-light); border-radius: 4px;"><%= acct.email %></code>
                <form method="POST" action="/integrations/google/disconnect" style="margin: 0;">
                  <input type="hidden" name="account" value="<%= acct.email %>">
                  <button type="submit" class="btn btn-danger btn-sm">Disconnect</button>
                </form>
              </div>
              <div style="display: flex; gap: 6px; flex-wrap: wrap;">
                <% for (const svc of acct.services) { %>
                  <% if (svc === 'gmail_send') { %>
                    <span class="status-badge status-connected">Draft & Send</span>
                  <% } else { %>
                    <span class="status-badge status-connected"><%= svc.charAt(0).toUpperCase() + svc.slice(1) %></span>
                  <% } %>
                <% } %>
              </div>
              <% if (missingServices.length > 0) { %>
                <div style="margin-top: 8px; font-size: 13px; color: var(--text-secondary);">
                  To add more services (e.g. Docs, Sheets), disconnect and reconnect with the services you want.
                </div>
              <% } %>
            </div>
          <% } %>

          <% const hasGmail = googleAccounts.some(a => a.services.includes('gmail')); %>
          <% if (hasGmail) { %>
            <form method="POST" action="/integrations/google/email-rules" style="padding: 12px 0; border-bottom: 1px solid var(--rule-light);">
              <div class="form-group">
                <label><strong>Gmail Email Rules</strong></label>
                <div class="hint" style="margin-bottom: 8px;">Control who your agent can read and respond to via Gmail.</div>
                <div style="display: flex; flex-direction: column; gap: 8px;">
                  <label style="display: flex; align-items: center; gap: 8px; font-size: 14px; cursor: pointer;">
                    <input type="radio" name="filter_mode" value="all" <%= gmailFilter.mode === 'all' ? 'checked' : '' %> class="gmail-filter-radio">
                    <span>Everyone</span>
                  </label>
                  <label style="display: flex; align-items: center; gap: 8px; font-size: 14px; cursor: pointer;">
                    <input type="radio" name="filter_mode" value="domains" <%= gmailFilter.mode === 'domains' ? 'checked' : '' %> class="gmail-filter-radio">
                    <span>All from the domain(s)</span>
                  </label>
                  <label style="display: flex; align-items: center; gap: 8px; font-size: 14px; cursor: pointer;">
                    <input type="radio" name="filter_mode" value="addresses" <%= gmailFilter.mode === 'addresses' ? 'checked' : '' %> class="gmail-filter-radio">
                    <span>Anyone on this list</span>
                  </label>
                </div>
              </div>

              <div id="gmail-domains-group" class="form-group" style="display: none;">
                <label for="gmail_filter_domains">Allowed Domains</label>
                <input type="text" id="gmail_filter_domains" name="filter_domains" value="<%= gmailFilter.domains.join(', ') %>" placeholder="e.g. hustlefund.com, example.com">
                <div class="hint">Comma-separated. Only emails from @these-domains will be processed.</div>
              </div>

              <div id="gmail-addresses-group" style="display: none;">
                <div class="form-group">
                  <label>Allowed Addresses</label>
                  <div style="display: flex; gap: 8px;">
                    <input type="email" id="gmail_address_input" placeholder="alice@example.com" style="flex: 1;">
                    <button type="button" id="gmail-add-address-btn" class="btn btn-sm" style="padding: 8px 16px;">Add</button>
                  </div>
                </div>
                <div id="gmail-address-tags" style="display: flex; flex-wrap: wrap; gap: 6px; margin-bottom: 12px;"></div>
                <input type="hidden" id="gmail_filter_addresses_hidden" name="filter_addresses" value="">
              </div>

              <div class="form-group" style="margin-top: 12px; padding-top: 12px; border-top: 1px solid var(--rule-light);">
                <label for="gmail_poll_interval">Check for new emails</label>
                <select id="gmail_poll_interval" name="poll_interval">
                  <option value="0" <%= gmailFilter.poll_interval === '0' || !gmailFilter.poll_interval ? 'selected' : '' %>>Off</option>
                  <option value="300000" <%= gmailFilter.poll_interval === '300000' ? 'selected' : '' %>>Every 5 minutes</option>
                  <option value="900000" <%= gmailFilter.poll_interval === '900000' ? 'selected' : '' %>>Every 15 minutes</option>
                  <option value="1800000" <%= gmailFilter.poll_interval === '1800000' ? 'selected' : '' %>>Every 30 minutes</option>
                  <option value="3600000" <%= gmailFilter.poll_interval === '3600000' ? 'selected' : '' %>>Every hour</option>
                </select>
                <div class="hint">Automatically check Gmail for new unread emails and respond.</div>
              </div>

              <div class="form-group">
                <label>When a new email arrives</label>
                <div style="display: flex; flex-direction: column; gap: 8px;">
                  <label style="display: flex; align-items: center; gap: 8px; font-size: 14px; cursor: pointer;">
                    <input type="radio" name="reply_mode" value="draft" <%= gmailFilter.reply_mode !== 'send' ? 'checked' : '' %>>
                    <span><strong>Create draft</strong> &mdash; Review before sending</span>
                  </label>
                  <label style="display: flex; align-items: center; gap: 8px; font-size: 14px; cursor: pointer;">
                    <input type="radio" name="reply_mode" value="send" <%= gmailFilter.reply_mode === 'send' ? 'checked' : '' %>>
                    <span><strong>Send immediately</strong> &mdash; Fully automated</span>
                  </label>
                </div>
              </div>

              <button type="submit" class="btn btn-sm">Save Rules</button>
            </form>
          <% } %>

          <% const connectedServices = googleAccounts.flatMap(a => a.services); %>
          <div style="<%= googleAccounts.length > 0 ? 'padding-top: 12px;' : '' %>">
            <form method="POST" action="/integrations/google/connect">
              <div class="form-group">
                <label>Select Google services to connect:</label>
                <div style="display: flex; flex-direction: column; gap: 8px; margin-top: 8px;">
                  <label style="display: flex; align-items: center; gap: 8px; font-size: 14px; cursor: pointer;">
                    <input type="checkbox" name="services" value="gmail" <%= connectedServices.includes('gmail') || googleAccounts.length === 0 ? 'checked' : '' %>>
                    <strong>Gmail</strong> &mdash; Read and label emails
                  </label>
                  <label style="display: flex; align-items: center; gap: 8px; font-size: 14px; cursor: pointer; padding-left: 28px;">
                    <input type="checkbox" name="services" value="gmail_send" <%= connectedServices.includes('gmail_send') ? 'checked' : '' %>>
                    <strong>Draft &amp; Send</strong> &mdash; Create drafts and send emails
                  </label>
                  <label style="display: flex; align-items: center; gap: 8px; font-size: 14px; cursor: pointer;">
                    <input type="checkbox" name="services" value="calendar" <%= connectedServices.includes('calendar') ? 'checked' : '' %>>
                    <strong>Calendar</strong> &mdash; View and create events
                  </label>
                  <label style="display: flex; align-items: center; gap: 8px; font-size: 14px; cursor: pointer;">
                    <input type="checkbox" name="services" value="drive" <%= connectedServices.includes('drive') ? 'checked' : '' %>>
                    <strong>Drive</strong> &mdash; Search and read files
                  </label>
                  <label style="display: flex; align-items: center; gap: 8px; font-size: 14px; cursor: pointer;">
                    <input type="checkbox" name="services" value="contacts" <%= connectedServices.includes('contacts') ? 'checked' : '' %>>
                    <strong>Contacts</strong> &mdash; Search contacts
                  </label>
                  <label style="display: flex; align-items: center; gap: 8px; font-size: 14px; cursor: pointer;">
                    <input type="checkbox" name="services" value="docs" <%= connectedServices.includes('docs') ? 'checked' : '' %>>
                    <strong>Docs</strong> &mdash; Create and edit Google Docs
                  </label>
                  <label style="display: flex; align-items: center; gap: 8px; font-size: 14px; cursor: pointer;">
                    <input type="checkbox" name="services" value="sheets" <%= connectedServices.includes('sheets') ? 'checked' : '' %>>
                    <strong>Sheets</strong> &mdash; Create, read, and write spreadsheets
                  </label>
                </div>
                <div class="hint" style="margin-top: 8px;">At least one service must be selected. Your agent will only access services you enable.</div>
              </div>
              <button type="submit" class="btn"><%= googleAccounts.length > 0 ? 'Add Another Google Account' : 'Connect with Google' %></button>
            </form>
          </div>
        </div>
      </details>

      <!-- Supabase -->
      <details class="integration-tile">
        <summary class="integration-tile-summary">
          <span class="integration-icon" style="background: #3ECF8E;"><img src="/logos/supabase.svg" alt="Supabase" width="24" height="24"></span>
          <div class="integration-tile-info">
            <h3>Supabase</h3>
            <p>Query and manage your database</p>
          </div>
          <span class="status-badge status-<%= supabase.status %>"><%= supabase.status %></span>
        </summary>
        <div class="integration-tile-body">
          <% if (supabase.error_message) { %>
            <p style="color: var(--danger); font-size: 13px; margin-bottom: 12px;"><%= supabase.error_message %></p>
          <% } %>

          <% if (supabase.status === 'connected') { %>
            <div style="margin-bottom: 12px;">
              <label style="font-size: 13px; color: var(--text-secondary);">Project URL</label>
              <div style="margin-top: 4px;">
                <code style="font-size: 14px; padding: 6px 10px; background: var(--bg); border: 1px solid var(--rule-light); border-radius: 4px;"><%= supabase.project_url %></code>
              </div>
            </div>
            <form method="POST" action="/integrations/supabase/permissions" style="margin-bottom: 12px; padding-top: 12px; border-top: 1px solid var(--rule-light);">
              <div class="form-group">
                <label>Agent Permissions</label>
                <div style="display: flex; flex-direction: column; gap: 8px; margin-top: 8px;">
                  <label style="display: flex; align-items: center; gap: 8px; font-size: 14px; cursor: pointer;">
                    <input type="checkbox" name="permissions" value="read" checked disabled>
                    <strong>Read</strong> &mdash; Query and list tables
                  </label>
                  <label style="display: flex; align-items: center; gap: 8px; font-size: 14px; cursor: pointer;">
                    <input type="checkbox" name="permissions" value="insert" <%= supabase.permissions.includes('insert') ? 'checked' : '' %>>
                    <strong>Insert</strong> &mdash; Add new records
                  </label>
                  <label style="display: flex; align-items: center; gap: 8px; font-size: 14px; cursor: pointer;">
                    <input type="checkbox" name="permissions" value="update" <%= supabase.permissions.includes('update') ? 'checked' : '' %>>
                    <strong>Update</strong> &mdash; Modify existing records
                  </label>
                </div>
              </div>
              <button type="submit" class="btn btn-sm">Save Permissions</button>
            </form>
            <form method="POST" action="/integrations/supabase/disconnect">
              <button type="submit" class="btn btn-danger btn-sm">Disconnect</button>
            </form>
          <% } else { %>
            <form method="POST" action="/integrations/supabase/connect">
              <p style="font-size: 14px; margin-bottom: 12px;">Connect your Supabase project so your agent can query your database. Here's where to <a href="https://theagentpost.co/guides/find-your-api-key#supabase" target="_blank" style="color: var(--accent); text-decoration: underline;">find your Project URL and API key</a></p>
              <div class="form-group">
                <label for="supabase_project_url">Project URL</label>
                <input type="url" id="supabase_project_url" name="project_url" placeholder="https://your-project.supabase.co" required>
                <div class="hint">Find this in your Supabase dashboard under Settings &rarr; API</div>
              </div>
              <div class="form-group">
                <label for="supabase_api_key">API Key</label>
                <input type="password" id="supabase_api_key" name="api_key" placeholder="eyJhbGciOiJIUzI1NiIs..." required>
                <div class="hint">Use the <code>anon</code> key for read-only, or <code>service_role</code> key if you want insert/update access</div>
              </div>
              <div class="form-group">
                <label>Agent Permissions</label>
                <div style="display: flex; flex-direction: column; gap: 8px; margin-top: 8px;">
                  <label style="display: flex; align-items: center; gap: 8px; font-size: 14px; cursor: pointer;">
                    <input type="checkbox" name="permissions" value="read" checked disabled>
                    <strong>Read</strong> &mdash; Query and list tables
                  </label>
                  <label style="display: flex; align-items: center; gap: 8px; font-size: 14px; cursor: pointer;">
                    <input type="checkbox" name="permissions" value="insert">
                    <strong>Insert</strong> &mdash; Add new records
                  </label>
                  <label style="display: flex; align-items: center; gap: 8px; font-size: 14px; cursor: pointer;">
                    <input type="checkbox" name="permissions" value="update">
                    <strong>Update</strong> &mdash; Modify existing records
                  </label>
                </div>
              </div>
              <button type="submit" class="btn">Connect</button>
            </form>
          <% } %>
        </div>
      </details>

      <!-- Airtable -->
      <details class="integration-tile">
        <summary class="integration-tile-summary">
          <span class="integration-icon" style="background: #18BFFF;"><img src="/logos/airtable.svg" alt="Airtable" width="24" height="24"></span>
          <div class="integration-tile-info">
            <h3>Airtable</h3>
            <p>Read and write to your bases</p>
          </div>
          <span class="status-badge status-<%= airtable.status %>"><%= airtable.status %></span>
        </summary>
        <div class="integration-tile-body">
          <% if (airtable.error_message) { %>
            <p style="color: var(--danger); font-size: 13px; margin-bottom: 12px;"><%= airtable.error_message %></p>
          <% } %>

          <% if (airtable.status === 'connected') { %>
            <div style="margin-bottom: 12px;">
              <p style="font-size: 14px;">Your Airtable account is connected. Your agent can list bases, read and write records.</p>
            </div>
            <form method="POST" action="/integrations/airtable/disconnect">
              <button type="submit" class="btn btn-danger btn-sm">Disconnect</button>
            </form>
          <% } else { %>
            <form method="POST" action="/integrations/airtable/connect">
              <p style="font-size: 14px; margin-bottom: 12px;">Connect your Airtable account so your agent can read and write to your bases.</p>
              <button type="submit" class="btn">Connect to Airtable</button>
            </form>
          <% } %>
        </div>
      </details>

      <!-- Notion -->
      <details class="integration-tile">
        <summary class="integration-tile-summary">
          <span class="integration-icon" style="background: #000;"><img src="/logos/notion.svg" alt="Notion" width="24" height="24"></span>
          <div class="integration-tile-info">
            <h3>Notion</h3>
            <p>Search, read, and update pages</p>
          </div>
          <span class="status-badge status-<%= notion.status %>"><%= notion.status %></span>
        </summary>
        <div class="integration-tile-body">
          <% if (notion.error_message) { %>
            <p style="color: var(--danger); font-size: 13px; margin-bottom: 12px;"><%= notion.error_message %></p>
          <% } %>

          <% if (notion.status === 'connected') { %>
            <div style="margin-bottom: 12px;">
              <label style="font-size: 13px; color: var(--text-secondary);">Connected Workspace</label>
              <div style="margin-top: 4px;">
                <code style="font-size: 14px; padding: 6px 10px; background: var(--bg); border: 1px solid var(--rule-light); border-radius: 4px;"><%= notion.workspace_name || 'Unknown' %></code>
              </div>
            </div>
            <form method="POST" action="/integrations/notion/disconnect">
              <button type="submit" class="btn btn-danger btn-sm">Disconnect</button>
            </form>
          <% } else { %>
            <form method="POST" action="/integrations/notion/connect">
              <p style="font-size: 14px; margin-bottom: 12px;">Connect your Notion workspace so your agent can search, read, and update your pages and databases.</p>
              <button type="submit" class="btn">Connect to Notion</button>
            </form>
          <% } %>
        </div>
      </details>

      <!-- Buffer -->
      <details class="integration-tile">
        <summary class="integration-tile-summary">
          <span class="integration-icon" style="background: #168AFF;"><img src="/logos/buffer.svg" alt="Buffer" width="24" height="24"></span>
          <div class="integration-tile-info">
            <h3>Buffer</h3>
            <p>Schedule social media posts</p>
          </div>
          <span class="status-badge status-<%= buffer.status === 'pending' ? 'disconnected' : buffer.status %>"><%= buffer.status === 'pending' ? 'choose org' : buffer.status %></span>
        </summary>
        <div class="integration-tile-body">
          <% if (buffer.error_message) { %>
            <p style="color: var(--danger); font-size: 13px; margin-bottom: 12px;"><%= buffer.error_message %></p>
          <% } %>

          <% if (buffer.status === 'pending' && buffer.pending_orgs.length > 0) { %>
            <p style="font-size: 14px; margin-bottom: 12px;">Your Buffer account has multiple organizations. Choose which one to connect:</p>
            <form method="POST" action="/integrations/buffer/select-org">
              <div style="display: flex; flex-direction: column; gap: 8px; margin-bottom: 12px;">
                <% buffer.pending_orgs.forEach(function(org, i) { %>
                  <label style="display: flex; align-items: center; gap: 8px; font-size: 14px; cursor: pointer; padding: 8px 12px; border: 1px solid var(--rule-light); border-radius: 6px;">
                    <input type="radio" name="organization_id" value="<%= org.id %>" <%= i === 0 ? '' : '' %> required>
                    <span><%= org.name %></span>
                  </label>
                <% }); %>
              </div>
              <div style="display: flex; gap: 8px;">
                <button type="submit" class="btn">Connect</button>
              </div>
            </form>
            <form method="POST" action="/integrations/buffer/disconnect" style="margin-top: 8px;">
              <button type="submit" class="btn btn-danger btn-sm">Cancel</button>
            </form>

          <% } else if (buffer.status === 'connected') { %>
            <div style="margin-bottom: 12px;">
              <label style="font-size: 13px; color: var(--text-secondary);">Connected Organization</label>
              <div style="margin-top: 4px;">
                <code style="font-size: 14px; padding: 6px 10px; background: var(--bg); border: 1px solid var(--rule-light); border-radius: 4px;"><%= buffer.organization_name || 'Connected' %></code>
              </div>
            </div>

            <% if (buffer.channels_error) { %>
              <p style="color: var(--text-secondary); font-size: 13px; margin-bottom: 12px;">Could not load channels. Try disconnecting and reconnecting.</p>
            <% } else if (buffer.channels.length > 0) { %>
              <form method="POST" action="/integrations/buffer/channels">
                <label style="font-size: 13px; color: var(--text-secondary); display: block; margin-bottom: 8px;">Channels your agent can post to:</label>
                <div style="display: flex; flex-direction: column; gap: 6px; margin-bottom: 12px;">
                  <% buffer.channels.forEach(function(ch) { %>
                    <label style="display: flex; align-items: center; gap: 8px; font-size: 14px; cursor: pointer;">
                      <input type="checkbox" name="channels" value="<%= ch.id %>"
                        <%= (buffer.selected_channels.length === 0 || buffer.selected_channels.includes(ch.id)) ? 'checked' : '' %>>
                      <span><%= ch.name %></span>
                      <span style="font-size: 12px; color: var(--text-secondary);">— <%= ch.service %></span>
                    </label>
                  <% }); %>
                </div>
                <button type="submit" class="btn btn-sm" style="margin-bottom: 12px;">Save Channels</button>
              </form>
            <% } else { %>
              <p style="color: var(--text-secondary); font-size: 13px; margin-bottom: 12px;">No channels found. Connect social accounts in Buffer first.</p>
            <% } %>

            <form method="POST" action="/integrations/buffer/disconnect">
              <button type="submit" class="btn btn-danger btn-sm">Disconnect</button>
            </form>
          <% } else { %>
            <form method="POST" action="/integrations/buffer/connect">
              <p style="font-size: 14px; margin-bottom: 12px;">Connect your Buffer account so your agent can schedule and publish social media posts across Twitter, Instagram, LinkedIn, and more.</p>
              <div class="form-group">
                <label for="buffer_api_key">API Key</label>
                <input type="password" id="buffer_api_key" name="api_key" placeholder="Bearer token..." required>
                <div class="hint">Generate your API key at <a href="https://publish.buffer.com/settings/api" target="_blank" style="color: var(--accent);">publish.buffer.com/settings/api</a></div>
              </div>
              <button type="submit" class="btn">Connect</button>
            </form>
          <% } %>
        </div>
      </details>

      <!-- Beehiiv -->
      <details class="integration-tile">
        <summary class="integration-tile-summary">
          <span class="integration-icon" style="background: #FD9B28;"><img src="/logos/beehiiv.svg" alt="Beehiiv" width="24" height="24"></span>
          <div class="integration-tile-info">
            <h3>Beehiiv</h3>
            <p>Draft &amp; manage newsletters</p>
          </div>
          <span class="status-badge status-<%= beehiiv.status === 'pending' ? 'disconnected' : beehiiv.status %>"><%= beehiiv.status === 'pending' ? 'choose pub' : beehiiv.status %></span>
        </summary>
        <div class="integration-tile-body">
          <% if (beehiiv.error_message) { %>
            <p style="color: var(--danger); font-size: 13px; margin-bottom: 12px;"><%= beehiiv.error_message %></p>
          <% } %>

          <% if (beehiiv.status === 'pending' && beehiiv.pending_pubs.length > 0) { %>
            <p style="font-size: 14px; margin-bottom: 12px;">Your Beehiiv account has multiple publications. Choose which one to connect:</p>
            <form method="POST" action="/integrations/beehiiv/select-pub">
              <div style="display: flex; flex-direction: column; gap: 8px; margin-bottom: 12px;">
                <% beehiiv.pending_pubs.forEach(function(pub) { %>
                  <label style="display: flex; align-items: center; gap: 8px; font-size: 14px; cursor: pointer; padding: 8px 12px; border: 1px solid var(--rule-light); border-radius: 6px;">
                    <input type="radio" name="publication_id" value="<%= pub.id %>" required>
                    <span><%= pub.name %></span>
                  </label>
                <% }); %>
              </div>
              <div style="display: flex; gap: 8px;">
                <button type="submit" class="btn">Connect</button>
              </div>
            </form>
            <form method="POST" action="/integrations/beehiiv/disconnect" style="margin-top: 8px;">
              <button type="submit" class="btn btn-danger btn-sm">Cancel</button>
            </form>

          <% } else if (beehiiv.status === 'connected') { %>
            <div style="margin-bottom: 12px;">
              <label style="font-size: 13px; color: var(--text-secondary);">Connected Publication</label>
              <div style="margin-top: 4px;">
                <code style="font-size: 14px; padding: 6px 10px; background: var(--bg); border: 1px solid var(--rule-light); border-radius: 4px;"><%= beehiiv.publication_name || 'Connected' %></code>
              </div>
            </div>

            <form method="POST" action="/integrations/beehiiv/templates">
              <label style="font-size: 13px; color: var(--text-secondary); display: block; margin-bottom: 8px;">Design Templates <span style="font-weight: normal;">(optional — find IDs in Beehiiv dashboard under My Templates)</span></label>
              <div id="beehiiv-templates" style="display: flex; flex-direction: column; gap: 6px; margin-bottom: 12px;">
                <% if (beehiiv.templates.length > 0) { %>
                  <% beehiiv.templates.forEach(function(t) { %>
                    <div style="display: flex; gap: 8px; align-items: center;">
                      <input type="text" name="template_name" value="<%= t.name %>" placeholder="Template name" style="flex: 1; padding: 6px 10px; border: 1px solid var(--rule-light); border-radius: 4px; font-size: 13px; background: var(--bg); color: var(--text);">
                      <input type="text" name="template_id" value="<%= t.id %>" placeholder="post_template_..." style="flex: 2; padding: 6px 10px; border: 1px solid var(--rule-light); border-radius: 4px; font-size: 13px; background: var(--bg); color: var(--text); font-family: monospace;">
                    </div>
                  <% }); %>
                <% } else { %>
                  <div style="display: flex; gap: 8px; align-items: center;">
                    <input type="text" name="template_name" placeholder="Template name" style="flex: 1; padding: 6px 10px; border: 1px solid var(--rule-light); border-radius: 4px; font-size: 13px; background: var(--bg); color: var(--text);">
                    <input type="text" name="template_id" placeholder="post_template_..." style="flex: 2; padding: 6px 10px; border: 1px solid var(--rule-light); border-radius: 4px; font-size: 13px; background: var(--bg); color: var(--text); font-family: monospace;">
                  </div>
                <% } %>
              </div>
              <div style="display: flex; gap: 8px; margin-bottom: 12px;">
                <button type="button" class="btn btn-sm" onclick="(function(){var c=document.getElementById('beehiiv-templates');var r=c.children[0].cloneNode(true);r.querySelectorAll('input').forEach(function(i){i.value=''});c.appendChild(r);})()">+ Add Template</button>
                <button type="submit" class="btn btn-sm">Save Templates</button>
              </div>
            </form>

            <form method="POST" action="/integrations/beehiiv/disconnect">
              <button type="submit" class="btn btn-danger btn-sm">Disconnect</button>
            </form>
          <% } else { %>
            <form method="POST" action="/integrations/beehiiv/connect">
              <p style="font-size: 14px; margin-bottom: 12px;">Connect your Beehiiv account so your agent can draft and manage newsletters.</p>
              <div class="form-group">
                <label for="beehiiv_api_key">API Key</label>
                <input type="password" id="beehiiv_api_key" name="api_key" placeholder="API key..." required>
                <div class="hint">Generate your API key in <a href="https://app.beehiiv.com/settings/integrations" target="_blank" style="color: var(--accent);">Beehiiv Settings → Integrations → API</a></div>
              </div>

              <details style="margin-bottom: 12px;">
                <summary style="font-size: 13px; color: var(--text-secondary); cursor: pointer;">Design Templates (optional)</summary>
                <div id="beehiiv-templates-setup" style="display: flex; flex-direction: column; gap: 6px; margin-top: 8px;">
                  <div style="display: flex; gap: 8px; align-items: center;">
                    <input type="text" name="template_name" placeholder="Template name" style="flex: 1; padding: 6px 10px; border: 1px solid var(--rule-light); border-radius: 4px; font-size: 13px; background: var(--bg); color: var(--text);">
                    <input type="text" name="template_id" placeholder="post_template_..." style="flex: 2; padding: 6px 10px; border: 1px solid var(--rule-light); border-radius: 4px; font-size: 13px; background: var(--bg); color: var(--text); font-family: monospace;">
                  </div>
                </div>
                <button type="button" class="btn btn-sm" style="margin-top: 8px;" onclick="(function(){var c=document.getElementById('beehiiv-templates-setup');var r=c.children[0].cloneNode(true);r.querySelectorAll('input').forEach(function(i){i.value=''});c.appendChild(r);})()">+ Add Template</button>
              </details>

              <button type="submit" class="btn">Connect</button>
            </form>
          <% } %>
        </div>
      </details>

      <!-- Luma -->
      <details class="integration-tile">
        <summary class="integration-tile-summary">
          <span class="integration-icon" style="background: #FF5C35;"><img src="/logos/luma.svg" alt="Luma" width="24" height="24"></span>
          <div class="integration-tile-info">
            <h3>Luma</h3>
            <p>Manage events and guest lists</p>
          </div>
          <span class="status-badge status-<%= luma.status %>"><%= luma.status %></span>
        </summary>
        <div class="integration-tile-body">
          <% if (luma.error_message) { %>
            <p style="color: var(--danger); font-size: 13px; margin-bottom: 12px;"><%= luma.error_message %></p>
          <% } %>

          <% if (luma.status === 'connected') { %>
            <div style="margin-bottom: 12px;">
              <label style="font-size: 13px; color: var(--text-secondary);">Connected Account</label>
              <div style="margin-top: 4px;">
                <code style="font-size: 14px; padding: 6px 10px; background: var(--bg); border: 1px solid var(--rule-light); border-radius: 4px;"><%= luma.user_name || 'Connected' %></code>
              </div>
            </div>
            <% if (luma.calendar_name) { %>
            <div style="margin-bottom: 12px;">
              <label style="font-size: 13px; color: var(--text-secondary);">Calendar</label>
              <div style="margin-top: 4px;">
                <code style="font-size: 14px; padding: 6px 10px; background: var(--bg); border: 1px solid var(--rule-light); border-radius: 4px;"><%= luma.calendar_name %></code>
              </div>
            </div>
            <% } %>
            <form method="POST" action="/integrations/luma/disconnect">
              <button type="submit" class="btn btn-danger btn-sm">Disconnect</button>
            </form>
          <% } else { %>
            <form method="POST" action="/integrations/luma/connect">
              <p style="font-size: 14px; margin-bottom: 12px;">Connect your Luma calendar so your agent can manage events, guest lists, and invitations. Requires a <a href="https://lu.ma/plus" target="_blank" style="color: var(--accent); text-decoration: underline;">Luma Plus</a> subscription.</p>
              <div class="form-group">
                <label for="luma_api_key">API Key</label>
                <input type="password" id="luma_api_key" name="api_key" placeholder="secret-..." required>
                <div class="hint">Find your API key at <a href="https://lu.ma/settings/api" target="_blank" style="color: var(--accent);">lu.ma/settings/api</a>. Each key is tied to one calendar.</div>
              </div>
              <button type="submit" class="btn">Connect</button>
            </form>
          <% } %>
        </div>
      </details>

      <!-- Twitter/X -->
      <details class="integration-tile">
        <summary class="integration-tile-summary">
          <span class="integration-icon" style="background: #000000;"><img src="/logos/twitter.svg" alt="X" width="24" height="24"></span>
          <div class="integration-tile-info">
            <h3>X (Twitter)</h3>
            <p>Post tweets and threads</p>
          </div>
          <span class="status-badge status-<%= twitter.status %>"><%= twitter.status %></span>
        </summary>
        <div class="integration-tile-body">
          <% if (twitter.error_message) { %>
            <p style="color: var(--danger); font-size: 13px; margin-bottom: 12px;"><%= twitter.error_message %></p>
          <% } %>

          <% if (twitter.status === 'connected') { %>
            <div style="margin-bottom: 12px;">
              <label style="font-size: 13px; color: var(--text-secondary);">Connected Account</label>
              <div style="margin-top: 4px;">
                <code style="font-size: 14px; padding: 6px 10px; background: var(--bg); border: 1px solid var(--rule-light); border-radius: 4px;">@<%= twitter.username || 'unknown' %></code>
              </div>
            </div>
            <form method="POST" action="/integrations/twitter/disconnect">
              <button type="submit" class="btn btn-danger btn-sm">Disconnect</button>
            </form>
          <% } else { %>
            <form method="POST" action="/integrations/twitter/connect">
              <p style="font-size: 14px; margin-bottom: 12px;">Connect your X account so your agent can post tweets, create threads, and schedule posts on your behalf.</p>
              <button type="submit" class="btn">Connect to X</button>
            </form>
          <% } %>
        </div>
      </details>

    </div><!-- /integration-grid -->
  </div>
</div>
<script>
(function () {
  var modeEl = document.getElementById("email_filter_mode");
  if (!modeEl) return;

  var domainGroup = document.getElementById("filter-domain-group");
  var addressesGroup = document.getElementById("filter-addresses-group");
  var addressInput = document.getElementById("filter_address_input");
  var addBtn = document.getElementById("add-address-btn");
  var tagsContainer = document.getElementById("address-tags");
  var hiddenInput = document.getElementById("filter_addresses_hidden");

  var addresses = <%= JSON.stringify(email.filter_addresses || []) %>;

  function updateVisibility() {
    var mode = modeEl.value;
    domainGroup.style.display = mode === "domain" ? "block" : "none";
    addressesGroup.style.display = mode === "addresses" ? "block" : "none";
  }

  function renderTags() {
    tagsContainer.innerHTML = "";
    hiddenInput.value = addresses.join(",");
    addresses.forEach(function (addr, i) {
      var tag = document.createElement("span");
      tag.style.cssText = "display: inline-flex; align-items: center; gap: 4px; padding: 4px 10px; background: var(--tag-bg); color: var(--accent); border-radius: 12px; font-size: 13px;";
      tag.textContent = addr;
      var removeBtn = document.createElement("button");
      removeBtn.type = "button";
      removeBtn.textContent = "\u00d7";
      removeBtn.style.cssText = "border: none; background: none; color: var(--accent); cursor: pointer; font-size: 16px; padding: 0; line-height: 1;";
      removeBtn.onclick = function () {
        addresses.splice(i, 1);
        renderTags();
      };
      tag.appendChild(removeBtn);
      tagsContainer.appendChild(tag);
    });
  }

  function addAddress() {
    var val = addressInput.value.trim().toLowerCase();
    if (val && val.includes("@") && addresses.indexOf(val) === -1) {
      addresses.push(val);
      renderTags();
      addressInput.value = "";
    }
    addressInput.focus();
  }

  addBtn.addEventListener("click", addAddress);
  addressInput.addEventListener("keydown", function (e) {
    if (e.key === "Enter") { e.preventDefault(); addAddress(); }
  });
  modeEl.addEventListener("change", updateVisibility);

  updateVisibility();
  renderTags();
})();

// Gmail email rules
(function () {
  var radios = document.querySelectorAll(".gmail-filter-radio");
  if (!radios.length) return;

  var domainsGroup = document.getElementById("gmail-domains-group");
  var addressesGroup = document.getElementById("gmail-addresses-group");
  var addressInput = document.getElementById("gmail_address_input");
  var addBtn = document.getElementById("gmail-add-address-btn");
  var tagsContainer = document.getElementById("gmail-address-tags");
  var hiddenInput = document.getElementById("gmail_filter_addresses_hidden");

  var addresses = <%= JSON.stringify((typeof gmailFilter !== 'undefined' && gmailFilter.addresses) || []) %>;

  function updateGmailVisibility() {
    var checked = document.querySelector(".gmail-filter-radio:checked");
    var mode = checked ? checked.value : "all";
    domainsGroup.style.display = mode === "domains" ? "block" : "none";
    addressesGroup.style.display = mode === "addresses" ? "block" : "none";
  }

  function renderGmailTags() {
    tagsContainer.innerHTML = "";
    hiddenInput.value = addresses.join(",");
    addresses.forEach(function (addr, i) {
      var tag = document.createElement("span");
      tag.style.cssText = "display: inline-flex; align-items: center; gap: 4px; padding: 4px 10px; background: var(--tag-bg); color: var(--accent); border-radius: 12px; font-size: 13px;";
      tag.textContent = addr;
      var removeBtn = document.createElement("button");
      removeBtn.type = "button";
      removeBtn.textContent = "\u00d7";
      removeBtn.style.cssText = "border: none; background: none; color: var(--accent); cursor: pointer; font-size: 16px; padding: 0; line-height: 1;";
      removeBtn.onclick = function () {
        addresses.splice(i, 1);
        renderGmailTags();
      };
      tag.appendChild(removeBtn);
      tagsContainer.appendChild(tag);
    });
  }

  function addGmailAddress() {
    var val = addressInput.value.trim().toLowerCase();
    if (val && val.includes("@") && addresses.indexOf(val) === -1) {
      addresses.push(val);
      renderGmailTags();
      addressInput.value = "";
    }
    addressInput.focus();
  }

  addBtn.addEventListener("click", addGmailAddress);
  addressInput.addEventListener("keydown", function (e) {
    if (e.key === "Enter") { e.preventDefault(); addGmailAddress(); }
  });
  radios.forEach(function (r) {
    r.addEventListener("change", updateGmailVisibility);
  });

  updateGmailVisibility();
  renderGmailTags();
})();
</script>
<%- include('partials/foot') %>

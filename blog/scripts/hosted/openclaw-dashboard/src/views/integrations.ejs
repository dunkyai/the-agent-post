<script>
(function () {
  var modeEl = document.getElementById("email_filter_mode");
  if (!modeEl) return;

  var domainGroup = document.getElementById("filter-domain-group");
  var addressesGroup = document.getElementById("filter-addresses-group");
  var addressInput = document.getElementById("filter_address_input");
  var addBtn = document.getElementById("add-address-btn");
  var tagsContainer = document.getElementById("address-tags");
  var hiddenInput = document.getElementById("filter_addresses_hidden");

  var addresses = <%= JSON.stringify(email.filter_addresses || []) %>;

  function updateVisibility() {
    var mode = modeEl.value;
    domainGroup.style.display = mode === "domain" ? "block" : "none";
    addressesGroup.style.display = mode === "addresses" ? "block" : "none";
  }

  function renderTags() {
    tagsContainer.innerHTML = "";
    hiddenInput.value = addresses.join(",");
    addresses.forEach(function (addr, i) {
      var tag = document.createElement("span");
      tag.style.cssText = "display: inline-flex; align-items: center; gap: 4px; padding: 4px 10px; background: var(--tag-bg); color: var(--accent); border-radius: 12px; font-size: 13px;";
      tag.textContent = addr;
      var removeBtn = document.createElement("button");
      removeBtn.type = "button";
      removeBtn.textContent = "\u00d7";
      removeBtn.style.cssText = "border: none; background: none; color: var(--accent); cursor: pointer; font-size: 16px; padding: 0; line-height: 1;";
      removeBtn.onclick = function () {
        addresses.splice(i, 1);
        renderTags();
      };
      tag.appendChild(removeBtn);
      tagsContainer.appendChild(tag);
    });
  }

  function addAddress() {
    var val = addressInput.value.trim().toLowerCase();
    if (val && val.includes("@") && addresses.indexOf(val) === -1) {
      addresses.push(val);
      renderTags();
      addressInput.value = "";
    }
    addressInput.focus();
  }

  addBtn.addEventListener("click", addAddress);
  addressInput.addEventListener("keydown", function (e) {
    if (e.key === "Enter") { e.preventDefault(); addAddress(); }
  });
  modeEl.addEventListener("change", updateVisibility);

  updateVisibility();
  renderTags();
})();

// Gmail email rules — tiered checkboxes
(function () {
  var checkboxes = document.querySelectorAll(".gmail-tier-checkbox");
  if (!checkboxes.length) return;

  var domainsGroup = document.getElementById("gmail-domains-group");
  var addressesGroup = document.getElementById("gmail-addresses-group");
  var addressInput = document.getElementById("gmail_address_input");
  var addBtn = document.getElementById("gmail-add-address-btn");
  var tagsContainer = document.getElementById("gmail-address-tags");
  var hiddenInput = document.getElementById("gmail_filter_addresses_hidden");

  var addresses = <%= JSON.stringify((typeof tierAddresses !== 'undefined' && tierAddresses.addresses) || []) %>;

  function updateGmailVisibility() {
    var domainsChecked = document.querySelector('.gmail-tier-checkbox[data-tier="domains"]');
    var addressesChecked = document.querySelector('.gmail-tier-checkbox[data-tier="addresses"]');
    domainsGroup.style.display = domainsChecked && domainsChecked.checked ? "block" : "none";
    addressesGroup.style.display = addressesChecked && addressesChecked.checked ? "block" : "none";
  }

  function renderGmailTags() {
    tagsContainer.innerHTML = "";
    hiddenInput.value = addresses.join(",");
    addresses.forEach(function (addr, i) {
      var tag = document.createElement("span");
      tag.style.cssText = "display: inline-flex; align-items: center; gap: 4px; padding: 4px 10px; background: var(--tag-bg); color: var(--accent); border-radius: 12px; font-size: 13px;";
      tag.textContent = addr;
      var removeBtn = document.createElement("button");
      removeBtn.type = "button";
      removeBtn.textContent = "\u00d7";
      removeBtn.style.cssText = "border: none; background: none; color: var(--accent); cursor: pointer; font-size: 16px; padding: 0; line-height: 1;";
      removeBtn.onclick = function () {
        addresses.splice(i, 1);
        renderGmailTags();
      };
      tag.appendChild(removeBtn);
      tagsContainer.appendChild(tag);
    });
  }

  function addGmailAddress() {
    var val = addressInput.value.trim().toLowerCase();
    if (val && val.includes("@") && addresses.indexOf(val) === -1) {
      addresses.push(val);
      renderGmailTags();
      addressInput.value = "";
    }
    addressInput.focus();
  }

  addBtn.addEventListener("click", addGmailAddress);
  addressInput.addEventListener("keydown", function (e) {
    if (e.key === "Enter") { e.preventDefault(); addGmailAddress(); }
  });
  checkboxes.forEach(function (cb) {
    cb.addEventListener("change", updateGmailVisibility);
  });

  updateGmailVisibility();
  renderGmailTags();
})();

// --- One (AuthKit via Pica) ---
// Replicates @picahq/authkit SDK behavior: opens a full-screen iframe to
// authkit.picaos.com with our link-token endpoint encoded in the URL.
(function () {
  var connectBtn = document.getElementById("one-connect-btn");
  if (!connectBtn) return;

  var AUTHKIT_BASE = "https://authkit.picaos.com";

  function closeAuthKit() {
    var el = document.getElementById("event-link");
    if (el) el.remove();
  }

  connectBtn.addEventListener("click", function () {
    // If already open, close
    if (document.getElementById("event-link")) {
      closeAuthKit();
      return;
    }

    // Build the config the AuthKit iframe expects
    var config = {
      linkTokenEndpoint: window.location.origin + "/integrations/one/link-token",
      linkHeaders: {},
      appTheme: "light",
    };

    var encoded = btoa(JSON.stringify(config));
    var url = AUTHKIT_BASE + "?data=" + encodeURIComponent(encoded);

    // Create full-screen iframe overlay (matching SDK behavior)
    var iframe = document.createElement("iframe");
    iframe.id = "event-link";
    iframe.src = url;
    iframe.style.cssText = "position:fixed;top:0;left:0;width:100%;height:100%;z-index:9999;border:none;background:transparent;";
    iframe.style.display = "none";
    iframe.style.visibility = "hidden";
    document.body.appendChild(iframe);

    iframe.onload = function () {
      setTimeout(function () {
        iframe.style.display = "block";
        iframe.style.visibility = "visible";
      }, 100);
    };
  });

  // Listen for AuthKit postMessage events
  window.addEventListener("message", function (event) {
    if (!event.data || typeof event.data !== "object" || !event.data.messageType) return;

    var type = event.data.messageType;
    var message = event.data.message;

    if (type === "LINK_SUCCESS") {
      closeAuthKit();

      // Send connection data to our backend, then reload
      var body = "key=" + encodeURIComponent(message.key || "") +
                 "&platform=" + encodeURIComponent(message.platform || "") +
                 "&name=" + encodeURIComponent(message.name || "");

      fetch("/integrations/one/connection", {
        method: "POST",
        headers: { "Content-Type": "application/x-www-form-urlencoded" },
        body: body,
      }).then(function () {
        window.location.href = "/integrations?flash=Platform+connected";
      }).catch(function () {
        window.location.reload();
      });
    } else if (type === "LINK_ERROR") {
      closeAuthKit();
      connectBtn.textContent = "Connect a Platform";
      alert("Connection failed: " + (message || "Unknown error"));
    } else if (type === "EXIT_EVENT_LINK") {
      closeAuthKit();
    }
  });
})();
</script>

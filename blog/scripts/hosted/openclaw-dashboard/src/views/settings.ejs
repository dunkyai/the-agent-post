<%- include('partials/head', { title: 'Settings' }) %>
<div class="app">
  <%- include('partials/nav', { active: 'settings' }) %>
  <div class="main">
    <h2>Settings</h2>
    <%- include('partials/flash', { flash }) %>

    <form method="POST" action="/settings">
      <div class="card">
        <h3>Identity</h3>
        <div class="form-group">
          <label for="agent_name">Agent Name</label>
          <input type="text" id="agent_name" name="agent_name" value="<%= agentName %>" placeholder="e.g. Archie, Nova, Pepper...">
          <div class="hint">Your agent will introduce itself with this name</div>
        </div>
      </div>

      <div class="card">
        <h3>System Prompt</h3>
        <div class="form-group">
          <label for="system_prompt">System prompt sent with every message</label>
          <textarea id="system_prompt" name="system_prompt" rows="8" placeholder="You are a helpful assistant..."><%= systemPrompt %></textarea>
        </div>
      </div>

      <div class="card">
        <h3>API Keys</h3>
        <div class="form-group">
          <label for="anthropic_api_key">Anthropic API Key</label>
          <input type="password" id="anthropic_api_key" name="anthropic_api_key"
            placeholder="<%= hasAnthropicKey ? '••••••••••••' : 'sk-ant-...' %>"
            value="">
          <div class="hint"><%= hasAnthropicKey ? 'Key is saved. Enter a new value to replace it, or leave blank to keep.' : 'Required for Claude models.' %></div>
        </div>
        <div class="form-group">
          <label for="openai_api_key">OpenAI API Key</label>
          <input type="password" id="openai_api_key" name="openai_api_key"
            placeholder="<%= hasOpenaiKey ? '••••••••••••' : 'sk-...' %>"
            value="">
          <div class="hint"><%= hasOpenaiKey ? 'Key is saved. Enter a new value to replace it, or leave blank to keep.' : 'Required for GPT models.' %></div>
        </div>
      </div>

      <div class="card">
        <h3>Model & Parameters</h3>
        <div class="form-group">
          <label for="model">Default Model</label>
          <select id="model" name="model">
            <% models.forEach(function(m) { %>
              <option value="<%= m.value %>" <%= model === m.value ? 'selected' : '' %>><%= m.label %></option>
            <% }); %>
          </select>
        </div>
        <div class="form-group">
          <label for="temperature">Temperature</label>
          <input type="number" id="temperature" name="temperature" value="<%= temperature %>" min="0" max="2" step="0.1">
          <div class="hint">0 = deterministic, 1 = creative, 2 = very random</div>
        </div>
        <div class="form-group">
          <label for="max_tokens">Max Tokens</label>
          <input type="number" id="max_tokens" name="max_tokens" value="<%= maxTokens %>" min="1" max="8192" step="1">
          <div class="hint">Maximum number of tokens in the response (1-8192)</div>
        </div>
      </div>

      <button type="submit" class="btn">Save Settings</button>
    </form>
  </div>
</div>
<%- include('partials/foot') %>

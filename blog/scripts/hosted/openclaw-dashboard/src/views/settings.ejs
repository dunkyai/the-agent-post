<%- include('partials/head', { title: 'Settings' }) %>
<div class="app">
  <%- include('partials/nav', { active: 'settings' }) %>
  <div class="main">
    <h2>Settings</h2>
    <%- include('partials/flash', { flash }) %>

    <form method="POST" action="/settings">
      <div class="card card-compact">
        <h3>Identity</h3>
        <div class="form-group">
          <label for="agent_name">Agent Name</label>
          <input type="text" id="agent_name" name="agent_name" value="<%= agentName %>" placeholder="e.g. Archie, Nova, Pepper...">
          <div class="hint">Your agent will introduce itself with this name</div>
        </div>
        <div class="form-group">
          <label for="user_name">Your Name</label>
          <input type="text" id="user_name" name="user_name" value="<%= userName %>" placeholder="e.g. Elizabeth, Alex...">
          <div class="hint">Shown in the chat window next to your messages</div>
        </div>
        <button type="submit" class="btn btn-sm">Save</button>
      </div>

      <div class="card card-compact">
        <h3>Agent Context</h3>
        <p style="font-size: 13px; color: var(--text-secondary); margin-bottom: 12px;">The more context you provide, the better your agent performs. These fields are automatically included in every conversation.</p>

        <div class="form-group">
          <label for="context_company">About Your Company</label>
          <textarea id="context_company" name="context_company" rows="3" placeholder="e.g. We're a seed-stage VC fund that invests in developer tools and infrastructure. We manage a $50M fund and have 23 portfolio companies."><%= contextCompany %></textarea>
          <div class="hint">What your company does, products, industry, size</div>
        </div>
        <div class="form-group">
          <label for="context_user">About You</label>
          <textarea id="context_user" name="context_user" rows="3" placeholder="e.g. I'm a GP focused on sourcing deals in the AI/ML space. I also manage LP relations and our quarterly reports."><%= contextUser %></textarea>
          <div class="hint">Your role, responsibilities, key contacts, working style</div>
        </div>
        <div class="form-group">
          <label for="context_rules">Rules & Guidelines</label>
          <textarea id="context_rules" name="context_rules" rows="3" placeholder="e.g. Always be professional. Never promise investments or share confidential LP information. Use a warm but concise tone."><%= contextRules %></textarea>
          <div class="hint">Things your agent should always or never do</div>
        </div>
        <div class="form-group">
          <label for="context_knowledge">Knowledge Base</label>
          <textarea id="context_knowledge" name="context_knowledge" rows="3" placeholder="e.g. Our fund size is $50M. Key LPs include Acme Endowment and Smith Family Office. Our typical check size is $500K-$2M."><%= contextKnowledge %></textarea>
          <div class="hint">Key facts, product info, pricing, domain knowledge your agent should know</div>
        </div>
        <button type="submit" class="btn btn-sm">Save</button>
      </div>

      <details class="card card-collapsible">
        <summary class="integration-toggle">
          <div class="integration-header">
            <h3>Advanced Settings</h3>
          </div>
          <span class="toggle-arrow"></span>
        </summary>
        <div class="integration-body">

      <div class="card card-compact" style="margin: 0 0 16px 0; box-shadow: none; border: 1px solid var(--rule-light);">
        <h3>System Prompt</h3>
        <div class="form-group">
          <label for="system_prompt">Custom system prompt sent with every message</label>
          <textarea id="system_prompt" name="system_prompt" rows="6" placeholder="e.g. You are a friendly assistant named Archie who works for Acme Corp..."><%= systemPrompt %></textarea>
          <div class="hint">For power users. The Agent Context fields above are injected automatically — this is for additional custom instructions.</div>
        </div>

        <details style="margin-bottom: 12px;">
          <summary style="font-size: 13px; color: var(--accent); cursor: pointer; user-select: none;">Auto-generate from LinkedIn</summary>
          <div style="padding-top: 12px;">
            <div class="form-group">
              <label for="linkedin_url">LinkedIn Profile URL</label>
              <div style="display: flex; gap: 8px;">
                <input type="url" id="linkedin_url" placeholder="https://linkedin.com/in/yourname" style="flex: 1;">
                <button type="button" id="research-btn" class="btn btn-sm" style="white-space: nowrap;">Research me</button>
              </div>
            </div>
            <div id="research-results" style="display: none; margin-bottom: 12px; padding: 10px; background: var(--bg); border: 1px solid var(--rule-light); border-radius: 6px; font-size: 13px;"></div>
            <button type="button" id="generate-prompt-btn" class="btn btn-sm">Generate System Prompt</button>
            <div id="generate-spinner" style="display: none; margin-top: 8px; font-size: 13px; color: var(--text-secondary);">Generating...</div>
          </div>
        </details>

        <button type="submit" class="btn btn-sm">Save</button>
      </div>

      <div class="card card-compact" style="margin: 0 0 16px 0; box-shadow: none; border: 1px solid var(--rule-light);">
        <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 8px;">
          <h3 style="margin-bottom: 0;">AI Provider</h3>
          <span id="key_status_badge" class="status-badge <%= (provider === 'anthropic' ? hasAnthropicKey : hasOpenaiKey) ? 'status-connected' : 'status-error' %>">
            <%= (provider === 'anthropic' ? hasAnthropicKey : hasOpenaiKey) ? 'API key saved' : 'No API key' %>
          </span>
        </div>
        <p style="margin-bottom: 8px; font-size: 13px; color: var(--text-secondary);">Pick a brain (LLM) for your OpenClaw. Here's where to <a href="https://theagentpost.co/guides/find-your-api-key" target="_blank" style="color: var(--accent); text-decoration: underline;">find your API key</a></p>
        <div class="form-group">
          <label for="provider">Provider</label>
          <select id="provider" name="provider">
            <option value="anthropic" <%= provider === 'anthropic' ? 'selected' : '' %>>Anthropic</option>
            <option value="openai" disabled>OpenAI (Coming soon)</option>
          </select>
        </div>
        <div class="form-group">
          <label for="api_key">API Key</label>
          <input type="password" id="api_key" name="api_key" placeholder="<%= provider === 'anthropic' ? (hasAnthropicKey ? '••••••••••••' : 'sk-ant-...') : (hasOpenaiKey ? '••••••••••••' : 'sk-...') %>" value="">
          <div class="hint" id="api_key_hint"><%= provider === 'anthropic' ? (hasAnthropicKey ? 'Key is saved. Enter a new value to replace it, or leave blank to keep.' : 'Get yours at console.anthropic.com under API Keys.') : (hasOpenaiKey ? 'Key is saved. Enter a new value to replace it, or leave blank to keep.' : 'Get yours at platform.openai.com under API Keys.') %></div>
        </div>
        <div class="form-group">
          <label for="model">Model</label>
          <select id="model" name="model">
          </select>
        </div>
        <button type="submit" class="btn btn-sm">Save</button>
      </div>

      <div class="card card-compact" style="margin: 0 0 16px 0; box-shadow: none; border: 1px solid var(--rule-light);">
        <h3>Parameters</h3>
        <div class="form-group">
          <label for="temperature">Temperature</label>
          <input type="number" id="temperature" name="temperature" value="<%= temperature %>" min="0" max="2" step="0.1">
          <div class="hint">0 = deterministic, 1 = creative, 2 = very random</div>
        </div>
        <div class="form-group">
          <label for="max_tokens">Max Tokens</label>
          <input type="number" id="max_tokens" name="max_tokens" value="<%= maxTokens %>" min="1" max="16384" step="1">
          <div class="hint">Max response length. A typical blog post is 1,000-5,000 tokens. (Max: 16,384)</div>
        </div>
        <button type="submit" class="btn btn-sm">Save</button>
      </div>

      <div class="card card-compact" style="margin: 0 0 0 0; box-shadow: none; border: 1px solid var(--rule-light);">
        <h3>Security</h3>
        <div class="form-group">
          <label for="session_expiry_days">Session Duration</label>
          <select id="session_expiry_days" name="session_expiry_days">
            <option value="1" <%= sessionExpiryDays === '1' ? 'selected' : '' %>>1 day</option>
            <option value="7" <%= sessionExpiryDays === '7' ? 'selected' : '' %>>7 days</option>
            <option value="30" <%= sessionExpiryDays === '30' || !sessionExpiryDays ? 'selected' : '' %>>30 days</option>
            <option value="90" <%= sessionExpiryDays === '90' ? 'selected' : '' %>>90 days</option>
          </select>
          <div class="hint">How long you stay logged in before needing to sign in again</div>
        </div>
        <button type="submit" class="btn btn-sm">Save</button>
      </div>

        </div>
      </details>
    </form>
  </div>
</div>
<script>
(function () {
  var providerEl = document.getElementById("provider");
  var modelEl = document.getElementById("model");
  var apiKeyEl = document.getElementById("api_key");
  var hintEl = document.getElementById("api_key_hint");
  var badgeEl = document.getElementById("key_status_badge");

  var models = {
    anthropic: [
      { value: "claude-sonnet-4-20250514", label: "Claude Sonnet 4" },
      { value: "claude-haiku-4-5-20251001", label: "Claude Haiku 4.5" },
      { value: "claude-opus-4-20250514", label: "Claude Opus 4" }
    ],
    openai: [
      { value: "gpt-4o", label: "GPT-4o" },
      { value: "gpt-4o-mini", label: "GPT-4o Mini" },
      { value: "gpt-4.1", label: "GPT-4.1" },
      { value: "gpt-4.1-mini", label: "GPT-4.1 Mini" }
    ]
  };

  var hints = {
    anthropic: {
      placeholder: "<%= hasAnthropicKey ? '••••••••••••' : 'sk-ant-...' %>",
      saved: <%= hasAnthropicKey ? 'true' : 'false' %>,
      text: 'Get yours at <a href="https://console.anthropic.com/settings/keys" target="_blank" style="color: var(--accent); text-decoration: underline;">console.anthropic.com</a> under API Keys.',
      savedText: "Key is saved. Enter a new value to replace it, or leave blank to keep."
    },
    openai: {
      placeholder: "<%= hasOpenaiKey ? '••••••••••••' : 'sk-...' %>",
      saved: <%= hasOpenaiKey ? 'true' : 'false' %>,
      text: 'Get yours at <a href="https://platform.openai.com/api-keys" target="_blank" style="color: var(--accent); text-decoration: underline;">platform.openai.com</a> under API Keys.',
      savedText: "Key is saved. Enter a new value to replace it, or leave blank to keep."
    }
  };

  var currentModel = "<%= model %>";

  function updateUI() {
    var provider = providerEl.value;
    var providerModels = models[provider] || [];
    var hint = hints[provider];

    modelEl.innerHTML = "";
    providerModels.forEach(function (m) {
      var opt = document.createElement("option");
      opt.value = m.value;
      opt.textContent = m.label;
      if (m.value === currentModel) opt.selected = true;
      modelEl.appendChild(opt);
    });

    apiKeyEl.placeholder = hint.placeholder;
    apiKeyEl.value = "";
    hintEl.innerHTML = hint.saved ? hint.savedText : hint.text;
    badgeEl.className = "status-badge " + (hint.saved ? "status-connected" : "status-error");
    badgeEl.textContent = hint.saved ? "API key saved" : "No API key";
  }

  // Clear placeholder dots on focus so user doesn't think they need to delete them
  apiKeyEl.addEventListener("focus", function () {
    if (!apiKeyEl.value) apiKeyEl.placeholder = "";
  });
  apiKeyEl.addEventListener("blur", function () {
    if (!apiKeyEl.value) {
      var hint = hints[providerEl.value];
      apiKeyEl.placeholder = hint.placeholder;
    }
  });

  providerEl.addEventListener("change", function () {
    currentModel = "";
    updateUI();
  });

  // Validate temperature and max_tokens on submit
  var form = document.querySelector("form[action='/settings']");
  form.addEventListener("submit", function (e) {
    var temp = parseFloat(document.getElementById("temperature").value);
    if (isNaN(temp) || temp < 0 || temp > 2) {
      e.preventDefault();
      alert("Temperature must be between 0 and 2.");
      return;
    }
    var tokens = parseInt(document.getElementById("max_tokens").value, 10);
    if (isNaN(tokens) || tokens < 1 || tokens > 16384) {
      e.preventDefault();
      alert("Max tokens must be between 1 and 16,384.");
      return;
    }
  });

  updateUI();
})();

// --- Generate System Prompt ---
(function () {
  var researchBtn = document.getElementById("research-btn");
  var generateBtn = document.getElementById("generate-prompt-btn");
  var spinner = document.getElementById("generate-spinner");
  var resultsDiv = document.getElementById("research-results");
  var systemPromptEl = document.getElementById("system_prompt");

  if (!researchBtn || !generateBtn) return;

  var researchData = null;

  researchBtn.addEventListener("click", function () {
    var url = document.getElementById("linkedin_url").value.trim();
    if (!url) { alert("Enter a LinkedIn URL first."); return; }

    researchBtn.disabled = true;
    researchBtn.textContent = "Researching...";
    resultsDiv.style.display = "none";

    fetch("/settings/research", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ linkedin_url: url })
    })
    .then(function (res) { return res.json(); })
    .then(function (data) {
      researchBtn.disabled = false;
      researchBtn.textContent = "Research me";
      if (data.error) {
        resultsDiv.style.display = "block";
        resultsDiv.textContent = "Research error: " + data.error;
        return;
      }
      researchData = data.summary;
      resultsDiv.style.display = "block";
      resultsDiv.innerHTML = "<strong>Found:</strong> " + data.summary.replace(/\n/g, "<br>");
    })
    .catch(function () {
      researchBtn.disabled = false;
      researchBtn.textContent = "Research me";
      resultsDiv.style.display = "block";
      resultsDiv.textContent = "Research failed. Try again or skip this step.";
    });
  });

  generateBtn.addEventListener("click", function () {
    var company = document.getElementById("context_company").value.trim();
    var role = document.getElementById("context_user").value.trim();
    var agentName = document.getElementById("agent_name").value.trim();

    if (!company && !role && !researchData) {
      alert("Fill in the Agent Context fields above or research your LinkedIn profile first.");
      return;
    }

    generateBtn.disabled = true;
    spinner.style.display = "block";

    fetch("/settings/generate-prompt", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({
        research: researchData || "",
        company: company,
        role: role,
        agent_purpose: "",
        tone: "friendly",
        agent_name: agentName
      })
    })
    .then(function (res) { return res.json(); })
    .then(function (data) {
      generateBtn.disabled = false;
      spinner.style.display = "none";
      if (data.error) {
        alert("Generation error: " + data.error);
        return;
      }
      systemPromptEl.value = data.prompt;
      systemPromptEl.scrollIntoView({ behavior: "smooth", block: "center" });
    })
    .catch(function () {
      generateBtn.disabled = false;
      spinner.style.display = "none";
      alert("Generation failed. Check your API key in Advanced Settings.");
    });
  });
})();
</script>
<%- include('partials/foot') %>

<%- include('partials/head', { title: 'Tasks' }) %>
<div class="app">
  <%- include('partials/nav', { active: 'tasks' }) %>
  <div class="main">
    <h2>Tasks</h2>

    <div id="tasks-list">
    <% if (tasks.length === 0) { %>
      <div class="card">
        <p style="color: var(--text-secondary); text-align: center;">
          No tasks yet. Send a message via chat to create one.
        </p>
      </div>
    <% } %>

    <% tasks.forEach(function(task) { %>
      <a href="/tasks/<%= task.task_id %>" style="text-decoration: none; color: inherit; display: block;">
        <div class="card" style="cursor: pointer; transition: border-color 0.15s;">
          <div class="integration-header">
            <div style="display: flex; align-items: center; gap: 8px;">
              <span style="font-size: 13px; color: var(--text-secondary); font-family: monospace;"><%= task.task_id %></span>
              <span class="task-channel-badge"><%= task.input.source_channel %></span>
            </div>
            <span class="status-badge task-status-<%= task.status %>">
              <%= task.status.replace('_', ' ') %>
            </span>
          </div>

          <div style="margin: 8px 0; font-size: 14px;">
            <%= task.input.raw_input.length > 150 ? task.input.raw_input.slice(0, 150) + '...' : task.input.raw_input %>
          </div>

          <div style="font-size: 12px; color: var(--text-secondary); display: flex; gap: 16px;">
            <span class="local-time" data-utc="<%= task.created_at %>"><%= task.created_at %></span>
            <% if (task.execution.duration_ms) { %>
              <span><%= (task.execution.duration_ms / 1000).toFixed(1) %>s</span>
            <% } %>
            <% if (task.execution.tool_calls_count) { %>
              <span><%= task.execution.tool_calls_count %> tool call<%= task.execution.tool_calls_count !== 1 ? 's' : '' %></span>
            <% } %>
          </div>
        </div>
      </a>
    <% }); %>
    </div>
  </div>
</div>

<style>
.task-channel-badge {
  font-size: 11px;
  padding: 2px 8px;
  border-radius: 4px;
  background: var(--bg-secondary, #f0f0f0);
  color: var(--text-secondary);
  text-transform: uppercase;
  font-weight: 500;
}
.task-status-pending { background: var(--bg-secondary, #e0e0e0); color: var(--text-secondary); }
.task-status-processing { background: #dbeafe; color: #1d4ed8; }
.task-status-awaiting_confirmation { background: #fef3c7; color: #92400e; }
.task-status-completed { background: #d1fae5; color: #065f46; }
.task-status-failed { background: #fee2e2; color: #991b1b; }
.task-status-cancelled { background: var(--bg-secondary, #e0e0e0); color: var(--text-secondary); }
</style>

<script>
(function() {
  var POLL_INTERVAL = 10000;
  var userTimezone = "<%= timezone %>";

  function formatLocal(utcStr, tz) {
    try {
      // SQLite datetime('now') omits Z — append it so JS parses as UTC
      var normalized = utcStr.indexOf('Z') === -1 && utcStr.indexOf('+') === -1 ? utcStr.replace(' ', 'T') + 'Z' : utcStr;
      var d = new Date(normalized);
      if (isNaN(d.getTime())) return utcStr;
      return d.toLocaleString('en-US', { timeZone: tz, month: 'short', day: 'numeric', hour: 'numeric', minute: '2-digit', hour12: true });
    } catch (e) { return utcStr; }
  }

  // Convert times on page load
  document.querySelectorAll('.local-time').forEach(function(el) {
    var utc = el.getAttribute('data-utc');
    if (utc) el.textContent = formatLocal(utc, userTimezone);
  });

  // Auto-refresh
  setInterval(function() {
    fetch('/tasks/api')
      .then(function(r) { return r.json(); })
      .then(function(data) {
        // Reload page if task count or any status changed
        // Simple approach: reload the page
        location.reload();
      })
      .catch(function() {});
  }, POLL_INTERVAL);
})();
</script>

<%- include('partials/foot') %>

<%- include('partials/head', { title: 'Tasks' }) %>
<div class="app">
  <%- include('partials/nav', { active: 'tasks' }) %>
  <div class="main">
    <h2>Tasks</h2>

    <% if (tasks.length === 0) { %>
      <p style="color: var(--text-secondary); text-align: center; padding: 32px 0;">
        No tasks yet. Send a message via chat to create one.
      </p>
    <% } else { %>
    <table class="tasks-table">
      <thead>
        <tr>
          <th>Status</th>
          <th>Source</th>
          <th>Input</th>
          <th>Duration</th>
          <th>Tool Calls</th>
          <th>Time</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% tasks.forEach(function(task) { %>
          <tr onclick="location.href='/tasks/<%= task.task_id %>'" style="cursor: pointer;">
            <td><span class="task-status task-status-<%= task.status %>"><%= task.status.replace('_', ' ') %></span></td>
            <td><span class="task-channel"><%= task.input.source_channel %></span></td>
            <td class="task-input"><%= task.input.raw_input.length > 120 ? task.input.raw_input.slice(0, 120) + '...' : task.input.raw_input %></td>
            <td class="task-meta"><% if (task.execution.duration_ms) { %><%= (task.execution.duration_ms / 1000).toFixed(1) %>s<% } else { %>-<% } %></td>
            <td class="task-meta"><% if (task.execution.tool_calls_count) { %><%= task.execution.tool_calls_count %><% } else { %>-<% } %></td>
            <td class="task-meta"><span class="local-time" data-utc="<%= task.created_at %>"><%= task.created_at %></span></td>
            <td class="task-meta" onclick="event.stopPropagation()">
              <a href="#" class="bug-link" data-task-id="<%= task.task_id %>" data-task-input="<%= task.input.raw_input.slice(0, 200).replace(/"/g, '&quot;') %>" onclick="showBugForm(this, event)">Report a bug</a>
              <div class="task-bug-form" style="display:none;">
                <textarea rows="2" placeholder="What did you expect to happen?"></textarea>
                <div style="display:flex;gap:6px;align-items:center;margin-top:6px;">
                  <button class="btn btn-sm" onclick="submitTaskBug(this)">Send</button>
                  <button class="btn btn-sm" onclick="closeBugForm(this)" style="background:transparent;color:var(--text-secondary);">Cancel</button>
                  <span class="bug-status" style="font-size:11px;"></span>
                </div>
              </div>
            </td>
          </tr>
        <% }); %>
      </tbody>
    </table>
    <% } %>
  </div>
</div>

<style>
.tasks-table {
  width: 100%;
  border-collapse: collapse;
  font-size: 13px;
}
.tasks-table th {
  text-align: left;
  font-size: 11px;
  text-transform: uppercase;
  color: var(--text-secondary);
  font-weight: 600;
  padding: 8px 12px;
  border-bottom: 2px solid var(--border, #e0e0e0);
  white-space: nowrap;
}
.tasks-table td {
  padding: 8px 12px;
  border-bottom: 1px solid var(--border, #e0e0e0);
  vertical-align: middle;
}
.tasks-table tbody tr:hover {
  background: var(--bg-secondary, #f5f5f5);
}
.task-input {
  max-width: 400px;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.task-meta {
  white-space: nowrap;
  color: var(--text-secondary);
}
.task-status {
  font-size: 11px;
  padding: 2px 8px;
  border-radius: 4px;
  font-weight: 500;
  white-space: nowrap;
}
.task-channel {
  font-size: 11px;
  text-transform: uppercase;
  color: var(--text-secondary);
  font-weight: 500;
}
.task-status-pending { background: var(--bg-secondary, #e0e0e0); color: var(--text-secondary); }
.task-status-processing { background: #dbeafe; color: #1d4ed8; }
.task-status-awaiting_confirmation { background: #fef3c7; color: #92400e; }
.task-status-completed { background: #d1fae5; color: #065f46; }
.task-status-failed { background: #fee2e2; color: #991b1b; }
.task-status-cancelled { background: var(--bg-secondary, #e0e0e0); color: var(--text-secondary); }
.bug-link {
  color: var(--text-secondary);
  font-size: 11px;
  text-decoration: none;
  white-space: nowrap;
}
.bug-link:hover { color: var(--accent); text-decoration: underline; }
.task-bug-form {
  margin-top: 8px;
  min-width: 260px;
}
.task-bug-form textarea {
  width: 100%;
  padding: 6px 8px;
  border: 1px solid var(--rule-light, #ddd);
  border-radius: 4px;
  font-size: 12px;
  font-family: inherit;
  resize: vertical;
  color: var(--fg);
  background: var(--bg);
}
.task-bug-form textarea:focus { outline: none; border-color: var(--accent); }
</style>

<script>
(function() {
  var POLL_INTERVAL = 10000;
  var userTimezone = "<%= timezone %>";

  function formatLocal(utcStr, tz) {
    try {
      var normalized = utcStr.indexOf('Z') === -1 && utcStr.indexOf('+') === -1 ? utcStr.replace(' ', 'T') + 'Z' : utcStr;
      var d = new Date(normalized);
      if (isNaN(d.getTime())) return utcStr;
      return d.toLocaleString('en-US', { timeZone: tz, month: 'short', day: 'numeric', hour: 'numeric', minute: '2-digit', hour12: true });
    } catch (e) { return utcStr; }
  }

  document.querySelectorAll('.local-time').forEach(function(el) {
    var utc = el.getAttribute('data-utc');
    if (utc) el.textContent = formatLocal(utc, userTimezone);
  });

  setInterval(function() {
    fetch('/tasks/api')
      .then(function(r) { return r.json(); })
      .then(function() { location.reload(); })
      .catch(function() {});
  }, POLL_INTERVAL);
})();

function showBugForm(link, e) {
  e.preventDefault();
  var td = link.parentElement;
  link.style.display = 'none';
  td.querySelector('.task-bug-form').style.display = 'block';
  td.querySelector('textarea').focus();
}
function closeBugForm(btn) {
  var td = btn.closest('td');
  td.querySelector('.task-bug-form').style.display = 'none';
  td.querySelector('.bug-link').style.display = '';
  td.querySelector('textarea').value = '';
  td.querySelector('.bug-status').textContent = '';
}
function submitTaskBug(btn) {
  var td = btn.closest('td');
  var textarea = td.querySelector('textarea');
  var status = td.querySelector('.bug-status');
  var feedback = textarea.value.trim();
  if (!feedback) { status.textContent = 'Please describe the issue.'; status.style.color = 'var(--danger)'; return; }
  var link = td.querySelector('.bug-link');
  var taskId = link.getAttribute('data-task-id');
  var taskInput = link.getAttribute('data-task-input');
  var msg = '[Task Bug Report]\nTask ID: ' + taskId + '\nTask Input: ' + taskInput + '\n\nExpected: ' + feedback;
  btn.disabled = true;
  status.textContent = 'Sending...';
  status.style.color = 'var(--text-secondary)';
  fetch('/bug-report', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ message: msg }) })
    .then(function(r) { return r.json(); })
    .then(function(data) {
      if (data.success) {
        status.textContent = 'Sent — thank you!';
        status.style.color = 'var(--success, green)';
        textarea.value = '';
        setTimeout(function() { closeBugForm(btn); }, 2000);
      } else {
        status.textContent = data.error || 'Failed.';
        status.style.color = 'var(--danger)';
      }
    })
    .catch(function() { status.textContent = 'Failed to send.'; status.style.color = 'var(--danger)'; })
    .finally(function() { btn.disabled = false; });
}
</script>

<%- include('partials/foot') %>

<%- include('partials/head', { title: 'Scheduled Jobs' }) %>
<div class="app">
  <%- include('partials/nav', { active: 'jobs' }) %>
  <div class="main">
    <h2>Scheduled Jobs</h2>
    <%- include('partials/flash', { flash }) %>

    <div class="card">
      <p style="color: var(--text-secondary); font-size: 14px; margin: 0;">
        You can schedule jobs through the <a href="/chat" style="color: var(--accent); text-decoration: underline;">chat</a> or via other communication channels (Slack, email).
      </p>
    </div>

    <div id="jobs-list">
    <% if (jobs.length === 0) { %>
      <div class="card">
        <p style="color: var(--text-secondary); text-align: center;">
          No scheduled jobs yet. Ask your agent to schedule one via chat or other channels.
        </p>
      </div>
    <% } %>

    <% jobs.forEach(function(job) { %>
      <div class="card">
        <div class="integration-header">
          <h3><%= job.name %></h3>
          <div style="display: flex; gap: 6px; align-items: center;">
            <% if (job.run_once) { %>
              <span class="status-badge" style="background: #FEF3C7; color: #92400E;"><%= job.run_once && !job.enabled && job.last_run ? 'completed' : 'one-time' %></span>
            <% } %>
            <span class="status-badge status-<%= job.enabled ? 'connected' : 'disconnected' %>">
              <%= job.enabled ? 'enabled' : 'disabled' %>
            </span>
          </div>
        </div>

        <div style="font-size: 13px; color: var(--text-secondary); margin-bottom: 12px;">
          <div><strong>Schedule:</strong> <%= job.schedule_description %></div>
          <div><strong>Prompt:</strong> <%= job.prompt.length > 120 ? job.prompt.slice(0, 120) + '...' : job.prompt %>
            <% if (job.prompt.length > 120) { %>
              <a href="#" class="prompt-toggle" style="color: var(--accent); text-decoration: underline; font-size: 12px; margin-left: 4px;" onclick="var el=this.nextElementSibling;var show=el.style.display==='none';el.style.display=show?'block':'none';this.textContent=show?'hide':'show more';return false;">show more</a>
              <span style="display:none; white-space: pre-wrap; word-break: break-word; margin-top: 4px;"><%= job.prompt %></span>
            <% } %>
          </div>
          <div><strong>Created via:</strong> <%= job.target_source %></div>
          <div><strong>Created by:</strong> <%= job.created_by %></div>
          <% if (job.next_run && job.next_run.trim()) { %>
            <div><strong>Next run:</strong> <span class="local-time" data-utc="<%= job.next_run %>"><%= job.next_run %></span></div>
          <% } %>
          <% if (job.last_run) { %>
            <div><strong>Last run:</strong> <span class="local-time" data-utc="<%= job.last_run %>"><%= job.last_run %></span></div>
          <% } %>
          <% if (job.last_error) { %>
            <div style="color: var(--danger);"><strong>Last error:</strong> <%= job.last_error %></div>
          <% } %>
          <% if (job.last_result) { %>
            <div><strong>Last result:</strong> <%= job.last_result.length > 120 ? job.last_result.slice(0, 120) + '...' : job.last_result %>
              <% if (job.last_result.length > 120) { %>
                <a href="#" class="prompt-toggle" style="color: var(--accent); text-decoration: underline; font-size: 12px; margin-left: 4px;" onclick="var el=this.nextElementSibling;var show=el.style.display==='none';el.style.display=show?'block':'none';this.textContent=show?'hide':'show more';return false;">show more</a>
                <span style="display:none; white-space: pre-wrap; word-break: break-word; margin-top: 4px;"><%= job.last_result %></span>
              <% } %>
            </div>
          <% } %>
        </div>

        <div style="display: flex; gap: 8px;">
          <form method="POST" action="/jobs/<%= job.id %>/run" style="display:inline;">
            <button type="submit" class="btn">Run Now</button>
          </form>
          <form method="POST" action="/jobs/<%= job.id %>/toggle" style="display:inline;">
            <button type="submit" class="btn"><%= job.enabled ? 'Disable' : 'Enable' %></button>
          </form>
          <form method="POST" action="/jobs/<%= job.id %>/delete" style="display:inline;"
                onsubmit="return confirm('Delete this job?')">
            <button type="submit" class="btn btn-danger">Delete</button>
          </form>
        </div>
      </div>
    <% }); %>
    </div>
  </div>
</div>
<script>
(function() {
  var POLL_INTERVAL = 30000;
  var userTimezone = "<%= timezone %>";
  function escapeHtml(s) { var d = document.createElement('div'); d.textContent = s; return d.innerHTML; }
  function truncate(s, n) { return s.length > n ? s.slice(0, n) + '...' : s; }
  function formatLocal(utcStr, tz) {
    try {
      var d = new Date(utcStr);
      if (isNaN(d.getTime())) return utcStr;
      return d.toLocaleString('en-US', { timeZone: tz, month: 'short', day: 'numeric', year: 'numeric', hour: 'numeric', minute: '2-digit', hour12: true, timeZoneName: 'short' });
    } catch (e) { return utcStr; }
  }

  // Convert server-rendered times on page load
  document.querySelectorAll('.local-time').forEach(function(el) {
    var utc = el.getAttribute('data-utc');
    if (utc) el.textContent = formatLocal(utc, userTimezone);
  });

  function refreshJobs() {
    fetch('/jobs/api').then(function(r) { return r.json(); }).then(function(data) {
      var jobs = data.jobs || data;
      var tz = data.timezone || userTimezone;
      var container = document.getElementById('jobs-list');
      if (!container) return;
      if (jobs.length === 0) {
        container.innerHTML = '<div class="card"><p style="color: var(--text-secondary); text-align: center;">No scheduled jobs yet. Ask your agent to schedule one via chat or other channels.</p></div>';
        return;
      }
      container.innerHTML = jobs.map(function(job) {
        return '<div class="card">'
          + '<div class="integration-header">'
          + '<h3>' + escapeHtml(job.name) + '</h3>'
          + '<div style="display: flex; gap: 6px; align-items: center;">'
          + (job.run_once ? '<span class="status-badge" style="background: #FEF3C7; color: #92400E;">' + (job.run_once && !job.enabled && job.last_run ? 'completed' : 'one-time') + '</span>' : '')
          + '<span class="status-badge status-' + (job.enabled ? 'connected' : 'disconnected') + '">'
          + (job.enabled ? 'enabled' : 'disabled') + '</span></div></div>'
          + '<div style="font-size: 13px; color: var(--text-secondary); margin-bottom: 12px;">'
          + '<div><strong>Schedule:</strong> ' + escapeHtml(job.schedule_description) + '</div>'
          + '<div><strong>Prompt:</strong> ' + escapeHtml(truncate(job.prompt, 120))
          + (job.prompt.length > 120 ? ' <a href="#" class="prompt-toggle" style="color: var(--accent); text-decoration: underline; font-size: 12px; margin-left: 4px;" onclick="var el=this.nextElementSibling;var show=el.style.display===\'none\';el.style.display=show?\'block\':\'none\';this.textContent=show?\'hide\':\'show more\';return false;">show more</a><span style="display:none; white-space: pre-wrap; word-break: break-word; margin-top: 4px;">' + escapeHtml(job.prompt) + '</span>' : '')
          + '</div>'
          + '<div><strong>Created via:</strong> ' + escapeHtml(job.target_source) + '</div>'
          + '<div><strong>Created by:</strong> ' + escapeHtml(job.created_by) + '</div>'
          + (job.next_run && job.next_run.trim() ? '<div><strong>Next run:</strong> ' + escapeHtml(formatLocal(job.next_run, tz)) + '</div>' : '')
          + (job.last_run ? '<div><strong>Last run:</strong> ' + escapeHtml(formatLocal(job.last_run, tz)) + '</div>' : '')
          + (job.last_error ? '<div style="color: var(--danger);"><strong>Last error:</strong> ' + escapeHtml(job.last_error) + '</div>' : '')
          + (job.last_result ? '<div><strong>Last result:</strong> ' + escapeHtml(truncate(job.last_result, 120))
          + (job.last_result.length > 120 ? ' <a href="#" class="prompt-toggle" style="color: var(--accent); text-decoration: underline; font-size: 12px; margin-left: 4px;" onclick="var el=this.nextElementSibling;var show=el.style.display===\'none\';el.style.display=show?\'block\':\'none\';this.textContent=show?\'hide\':\'show more\';return false;">show more</a><span style="display:none; white-space: pre-wrap; word-break: break-word; margin-top: 4px;">' + escapeHtml(job.last_result) + '</span>' : '')
          + '</div>' : '')
          + '</div>'
          + '<div style="display: flex; gap: 8px;">'
          + '<form method="POST" action="/jobs/' + job.id + '/run" style="display:inline;">'
          + '<button type="submit" class="btn">Run Now</button></form>'
          + '<form method="POST" action="/jobs/' + job.id + '/toggle" style="display:inline;">'
          + '<button type="submit" class="btn">' + (job.enabled ? 'Disable' : 'Enable') + '</button></form>'
          + '<form method="POST" action="/jobs/' + job.id + '/delete" style="display:inline;" onsubmit="return confirm(\'Delete this job?\')">'
          + '<button type="submit" class="btn btn-danger">Delete</button></form>'
          + '</div></div>';
      }).join('');
    }).catch(function() {});
  }

  setInterval(refreshJobs, POLL_INTERVAL);
})();
</script>
<%- include('partials/foot') %>
